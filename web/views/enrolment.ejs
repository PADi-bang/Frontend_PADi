<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Enrolment Kelas - App_PADi</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-slate-100 flex font-sans">
    
    <aside class="w-64 h-screen bg-black text-gray-400 p-6 flex flex-col fixed rounded-r-3xl shadow-2xl z-20">
        <div class="text-3xl font-bold text-white mb-12 mt-4 tracking-widest pl-2">PADi</div>
        <nav class="flex-1 space-y-3">
            <a href="/dashboard" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">⊞</span> Dashboard
            </a>
            <a href="/daftar-siswa" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">👤</span> Daftar Siswa
            </a>
            <a href="/daftar-guru" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">👨‍🏫</span> Daftar Guru
            </a>
            <a href="/jadwal" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">📅</span> Jadwal
            </a>
            <a href="/master-data" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">🗂️</span> Master Data
            </a>
            <a href="/enrolment" class="flex items-center gap-4 p-3.5 bg-blue-600 text-white rounded-2xl shadow-lg shadow-blue-600/40 transition">
                <span class="text-lg">🎓</span> Enrolment Kelas
            </a>
        </nav>
        <div class="mt-auto mb-4">
            <a href="/logout" class="flex justify-center items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 px-4 rounded-full transition shadow-lg shadow-blue-600/30">
                <span class="text-lg">⎋</span> LOGOUT
            </a>
        </div>
    </aside>

    <main class="flex-1 ml-64 p-8">
        
        <div class="bg-blue-600 rounded-3xl p-4 flex justify-between items-center text-white mb-8 shadow-lg shadow-blue-600/20">
            <h1 class="text-2xl font-bold ml-4">Enrolment Kelas</h1>

            <div class="flex items-center gap-6 pr-4">
                <div class="flex items-center gap-3 pl-6 cursor-pointer">
                    <span class="text-sm font-bold tracking-wide uppercase">Admin PADI</span>
                    <div class="w-9 h-9 bg-white rounded-full flex items-center justify-center text-blue-600 font-bold text-xs">AD</div>
                </div>
            </div>
        </div>

        <div class="mb-8">
            <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">⚙️ Pengaturan Tingkat Kelas</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <% if (typeof prefixData !== 'undefined') { %>
                    <% prefixData.forEach(p => { %>
                        <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col justify-between">
                            <div>
                                <h3 class="text-lg font-bold text-blue-600 mb-3">Tingkat <%= p.prefix %></h3>
                                <p class="text-sm text-gray-500 mb-1">Angkatan: <span class="font-bold text-gray-800"><%= p.angkatanName %></span></p>
                                <p class="text-sm text-gray-500">Tahun Akademik: <span class="font-bold text-gray-800"><%= p.taName %></span></p>
                            </div>
                            <div class="mt-5 flex gap-3">
                                <button onclick="openAturTingkatModal('<%= p.prefix %>', '<%= p.angkatanId %>')" class="flex-1 bg-yellow-100 text-yellow-600 py-2.5 rounded-xl text-xs font-bold hover:bg-yellow-200 transition">Atur Tingkat</button>
                                <% if (p.angkatanId) { %>
                                    <form action="/enrolment/reset-tingkat" method="POST" class="flex-1" onsubmit="return confirmResetTingkat(event, this, '<%= p.prefix %>');">
                                        <input type="hidden" name="prefix" value="<%= p.prefix %>">
                                        <button type="submit" class="w-full bg-red-100 text-red-600 py-2.5 rounded-xl text-xs font-bold hover:bg-red-200 transition">Kosongkan</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden p-6">
            <table class="w-full text-left">
                <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase tracking-wider font-bold">
                    <tr>
                        <th class="px-6 py-4">Nama Kelas</th>
                        <th class="px-6 py-4">Angkatan</th>
                        <th class="px-6 py-4">Tahun Akademik</th>
                        <th class="px-6 py-4">Keterangan</th>
                        <th class="px-6 py-4">Siswa</th>
                        <th class="px-6 py-4">Wali Kelas</th>
                        <th class="px-6 py-4 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y text-sm">
                    <% if (typeof enrolmentData !== 'undefined' && enrolmentData.length > 0) { %>
                        <% enrolmentData.forEach(function(row) { %>
                            <tr class="hover:bg-slate-50 transition">
                                <td class="px-6 py-4 font-bold text-blue-600"><%= row.masterKelas.namaKelas %></td>
                                <% if (row.enrolment) { %>
                                    <td class="px-6 py-4 font-bold text-gray-700"><%= row.enrolment.masterAngkatan.nomorAngkatan %></td>
                                    <td class="px-6 py-4 text-gray-600">
                                        <%= row.enrolment.masterTahunAkademik.tahunAjaran %> 
                                        <span class="text-[10px] bg-slate-200 px-2 py-0.5 rounded-md ml-1"><%= row.enrolment.masterTahunAkademik.semester %></span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2">
                                            <span class="text-gray-500 italic"><%= row.enrolment.keterangan || '-' %></span>
                                            <% const kId = row.enrolment.keterangan ? row.enrolment.keterangan.replace(/'/g, "\\'") : ''; %>
                                            <button onclick="openEditKeteranganModal('<%= row.masterKelas.id %>', '<%= row.masterKelas.namaKelas %>', '<%= kId %>')" class="text-blue-400 hover:text-blue-600 transition" title="Edit Keterangan">✏️</button>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4"><span class="bg-blue-100 text-blue-700 font-bold px-3 py-1 rounded-full text-xs"><%= row.enrolment._count.enrolmentSiswa %> Siswa</span></td>
                                    <td class="px-6 py-4">
                                        <% if (row.enrolment.enrolmentGuru && row.enrolment.enrolmentGuru.length > 0) { %>
                                            <span class="bg-green-100 text-green-700 font-bold px-3 py-1 rounded-full text-xs"><%= row.enrolment.enrolmentGuru[0].guru.namaLengkap %></span>
                                        <% } else { %>
                                            <span class="bg-yellow-100 text-yellow-700 font-bold px-3 py-1 rounded-full text-xs">Belum Diatur</span>
                                        <% } %>
                                    </td>
                                <% } else { %>
                                    <td class="px-6 py-4 text-gray-400 italic">Belum diset</td>
                                    <td class="px-6 py-4 text-gray-400 italic">Belum diset</td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2">
                                            <span class="text-gray-400 italic">-</span>
                                            <button onclick="openEditKeteranganModal('<%= row.masterKelas.id %>', '<%= row.masterKelas.namaKelas %>', '')" class="text-blue-400 hover:text-blue-600 transition" title="Edit Keterangan">✏️</button>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4"><span class="bg-gray-100 text-gray-500 font-bold px-3 py-1 rounded-full text-xs">0 Siswa</span></td>
                                    <td class="px-6 py-4"><span class="bg-gray-100 text-gray-500 font-bold px-3 py-1 rounded-full text-xs">Belum Diatur</span></td>
                                <% } %>
                                <td class="px-6 py-4 flex justify-center gap-2">
                                    <% if (row.enrolment) { %>
                                        <a href="/enrolment/<%= row.enrolment.id %>" class="bg-blue-100 text-blue-600 px-4 py-1.5 rounded-lg text-xs font-bold hover:bg-blue-200 transition">Detail Siswa & Guru</a>
                                    <% } else { %>
                                        <span class="text-xs text-gray-400 italic">Atur tingkat dulu</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="7" class="px-8 py-8 text-center text-gray-500 font-bold">Belum ada master kelas yang dibuat.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <div id="modalAturTingkat" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl relative">
            <button onclick="toggleModal('modalAturTingkat')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-2">Atur Tingkat <span id="aturPrefixName"></span></h2>
            <p class="text-sm text-gray-500 mb-6">Pengaturan ini akan diterapkan ke semua kelas di tingkat ini secara otomatis.</p>
            <form action="/enrolment/edit-tingkat" method="POST" class="space-y-4">
                <input type="hidden" name="prefix" id="aturPrefix">
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase">Pilih Master Angkatan</label>
                    <select name="angkatanId" id="aturAngkatan" required class="w-full mt-1 bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-blue-500">
                        <option value="">-- Pilih Angkatan --</option>
                        <% masterData.angkatan.forEach(a => { %>
                            <option value="<%= a.id %>"><%= a.nomorAngkatan %></option>
                        <% }) %>
                    </select>
                    <div class="mt-4 p-3 bg-blue-50 border border-blue-100 rounded-xl flex items-start gap-2">
                        <span class="text-blue-500 mt-0.5">ℹ️</span>
                        <p class="text-xs text-blue-700 leading-relaxed">Kelas ini akan otomatis dipasangkan dengan <b>Tahun Akademik</b> yang saat ini sedang aktif di pengaturan Master Data.</p>
                    </div>
                </div>
                <input type="hidden" name="sekolahId" value="1">
                <button type="submit" class="w-full bg-blue-600 text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-blue-700">Terapkan</button>
            </form>
        </div>
    </div>

    <div id="modalEditKeterangan" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl relative">
            <button onclick="toggleModal('modalEditKeterangan')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-2">Edit Keterangan</h2>
            <p id="editKetKelasName" class="text-sm font-bold text-blue-600 mb-6 bg-blue-50 px-3 py-1.5 rounded-lg inline-block"></p>
            <form id="editKetForm" method="POST" class="space-y-4">
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase">Keterangan (Opsional)</label>
                    <input type="text" name="keterangan" id="editKetValue" placeholder="Keterangan tambahan..." class="w-full mt-1 bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-blue-500">
                </div>
                <button type="submit" class="w-full bg-blue-600 text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-blue-700">Simpan Keterangan</button>
            </form>
        </div>
    </div>

    <script>
        // Tampilkan error dari URL (Validasi Unik)
        const urlParams = new URLSearchParams(window.location.search);
        const errorMsg = urlParams.get('error');
        if (errorMsg) {
            Swal.fire({
                title: 'Tidak Diizinkan!',
                text: decodeURIComponent(errorMsg).replace(/_/g, ' '),
                icon: 'error',
                confirmButtonColor: '#3085d6',
                confirmButtonText: 'Tutup'
            });
            window.history.replaceState(null, null, window.location.pathname);
        }

        function toggleModal(modalID) {
            const modal = document.getElementById(modalID);
            modal.classList.toggle('hidden');
        }

        function openAturTingkatModal(prefix, angkatanId) {
            document.getElementById('aturPrefixName').innerText = prefix;
            document.getElementById('aturPrefix').value = prefix;
            document.getElementById('aturAngkatan').value = angkatanId || '';
            toggleModal('modalAturTingkat');
        }

        function openEditKeteranganModal(kelasId, namaKelas, keterangan) {
            document.getElementById('editKetKelasName').innerText = namaKelas;
            document.getElementById('editKetForm').action = '/enrolment/edit-keterangan/' + kelasId;
            document.getElementById('editKetValue').value = keterangan || '';
            toggleModal('modalEditKeterangan');
        }

        function confirmResetTingkat(e, form, prefix) {
            e.preventDefault();
            Swal.fire({
                title: `Kosongkan Tingkat ${prefix}?`, 
                text: "Semua kelas di tingkat ini akan dilepas angkatan, TA, beserta seluruh siswa dan gurunya. Yakin?", 
                icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#ef4444', cancelButtonColor: '#64748b', confirmButtonText: 'Ya, Kosongkan!'
            }).then((result) => {
                if (result.isConfirmed) form.submit();
            });
        }
    </script>

    

    


    </body>
</html>
