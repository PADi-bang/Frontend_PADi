<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Enrolment Kelas - App_PADi</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-slate-100 flex font-sans">
    
    <aside class="w-64 h-screen bg-black text-gray-400 p-6 flex flex-col fixed rounded-r-3xl shadow-2xl z-20">
        <div class="text-3xl font-bold text-white mb-12 mt-4 tracking-widest pl-2">PADi</div>
        <nav class="flex-1 space-y-3">
            <a href="/dashboard" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">⊞</span> Dashboard
            </a>
            <a href="/daftar-siswa" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">👤</span> Daftar Siswa
            </a>
            <a href="/daftar-guru" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">👨‍🏫</span> Daftar Guru
            </a>
            <a href="/jadwal" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">📅</span> Jadwal
            </a>
            <a href="/master-data" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">🗂️</span> Master Data
            </a>
            <a href="/enrolment" class="flex items-center gap-4 p-3.5 bg-blue-600 text-white rounded-2xl shadow-lg shadow-blue-600/40 transition">
                <span class="text-lg">🎓</span> Enrolment Kelas
            </a>
        </nav>
        <div class="mt-auto mb-4">
            <a href="/logout" class="flex justify-center items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 px-4 rounded-full transition shadow-lg shadow-blue-600/30">
                <span class="text-lg">⎋</span> LOGOUT
            </a>
        </div>
    </aside>

    <main class="flex-1 ml-64 p-8">
        
        <div class="bg-blue-600 rounded-3xl p-4 flex justify-between items-center text-white mb-8 shadow-lg shadow-blue-600/20">
            <h1 class="text-2xl font-bold ml-4">Enrolment Kelas</h1>

            <div class="flex items-center gap-6 pr-4">
                <div class="flex items-center gap-3 pl-6 cursor-pointer">
                    <span class="text-sm font-bold tracking-wide uppercase">Admin PADI</span>
                    <div class="w-9 h-9 bg-white rounded-full flex items-center justify-center text-blue-600 font-bold text-xs">AD</div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden p-6">
            <table class="w-full text-left">
                <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase tracking-wider font-bold">
                    <tr>
                        <th class="px-6 py-4">Nama Kelas</th>
                        <th class="px-6 py-4">Angkatan</th>
                        <th class="px-6 py-4">Tahun Akademik</th>
                        <th class="px-6 py-4">Keterangan</th>
                        <th class="px-6 py-4">Siswa</th>
                        <th class="px-6 py-4">Guru</th>
                        <th class="px-6 py-4 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y text-sm">
                    <% if (typeof enrolmentData !== 'undefined' && enrolmentData.length > 0) { %>
                        <% enrolmentData.forEach(function(row) { %>
                            <tr class="hover:bg-slate-50 transition">
                                <td class="px-6 py-4 font-bold text-blue-600"><%= row.masterKelas.namaKelas %></td>
                                <% if (row.enrolment) { %>
                                    <td class="px-6 py-4 font-bold text-gray-700"><%= row.enrolment.masterAngkatan.nomorAngkatan %></td>
                                    <td class="px-6 py-4 text-gray-600">
                                        <%= row.enrolment.masterTahunAkademik.tahunAjaran %> 
                                        <span class="text-[10px] bg-slate-200 px-2 py-0.5 rounded-md ml-1"><%= row.enrolment.masterTahunAkademik.semester %></span>
                                    </td>
                                    <td class="px-6 py-4 text-gray-500 italic"><%= row.enrolment.keterangan || '-' %></td>
                                    <td class="px-6 py-4"><span class="bg-blue-100 text-blue-700 font-bold px-3 py-1 rounded-full text-xs"><%= row.enrolment._count.enrolmentSiswa %> Siswa</span></td>
                                    <td class="px-6 py-4"><span class="bg-green-100 text-green-700 font-bold px-3 py-1 rounded-full text-xs"><%= row.enrolment._count.enrolmentGuru %> Guru</span></td>
                                <% } else { %>
                                    <td class="px-6 py-4 text-gray-400 italic">Belum diset</td>
                                    <td class="px-6 py-4 text-gray-400 italic">Belum diset</td>
                                    <td class="px-6 py-4 text-gray-400 italic">-</td>
                                    <td class="px-6 py-4"><span class="bg-gray-100 text-gray-500 font-bold px-3 py-1 rounded-full text-xs">0 Siswa</span></td>
                                    <td class="px-6 py-4"><span class="bg-gray-100 text-gray-500 font-bold px-3 py-1 rounded-full text-xs">0 Guru</span></td>
                                <% } %>
                                <%
                                    const aId = row.enrolment ? row.enrolment.angkatanId : '';
                                    const tId = row.enrolment ? row.enrolment.tahunAkademikId : '';
                                    const kId = row.enrolment ? (row.enrolment.keterangan || '') : '';
                                %>
                                <td class="px-6 py-4 flex justify-center gap-2">
                                    <button onclick="openAturModal('<%= row.masterKelas.id %>', '<%= row.masterKelas.namaKelas %>', '<%= aId %>', '<%= tId %>', '<%= kId %>')" class="bg-yellow-100 text-yellow-600 px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-yellow-200 transition">Atur</button>
                                    
                                    <% if (row.enrolment) { %>
                                        <a href="/enrolment/<%= row.enrolment.id %>" class="bg-blue-100 text-blue-600 px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-blue-200 transition">Detail</a>
                                        <form action="/enrolment/reset/<%= row.masterKelas.id %>" method="POST" class="inline" onsubmit="return confirmReset(event, this);">
                                            <button type="submit" class="bg-red-100 text-red-600 px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-red-200 transition">Kosongkan</button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="7" class="px-8 py-8 text-center text-gray-500 font-bold">Belum ada master kelas yang dibuat.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <div id="modalAturEnrolment" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl relative">
            <button onclick="toggleModal('modalAturEnrolment')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-2">Atur Enrolment</h2>
            <p id="aturKelasName" class="text-sm font-bold text-blue-600 mb-6 bg-blue-50 px-3 py-1.5 rounded-lg inline-block"></p>
            <form id="aturForm" method="POST" class="space-y-4">
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase">Pilih Master Angkatan</label>
                    <select name="angkatanId" id="aturAngkatan" required class="w-full mt-1 bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-blue-500">
                        <option value="">-- Pilih Angkatan --</option>
                        <% masterData.angkatan.forEach(a => { %>
                            <option value="<%= a.id %>"><%= a.nomorAngkatan %></option>
                        <% }) %>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase">Pilih Tahun Akademik</label>
                    <select name="tahunAkademikId" id="aturTa" required class="w-full mt-1 bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-blue-500">
                        <option value="">-- Pilih Tahun Akademik --</option>
                        <% masterData.ta.forEach(t => { %>
                            <option value="<%= t.id %>"><%= t.tahunAjaran %> (<%= t.semester %>)</option>
                        <% }) %>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase">Keterangan (Opsional)</label>
                    <input type="text" name="keterangan" id="aturKet" placeholder="Keterangan tambahan..." class="w-full mt-1 bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-blue-500">
                </div>
                <input type="hidden" name="sekolahId" value="1">
                <button type="submit" class="w-full bg-blue-600 text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-blue-700">Simpan Pengaturan</button>
            </form>
        </div>
    </div>

    <script>
        // Tampilkan error dari URL (Validasi Unik)
        const urlParams = new URLSearchParams(window.location.search);
        const errorMsg = urlParams.get('error');
        if (errorMsg) {
            Swal.fire({
                title: 'Tidak Diizinkan!',
                text: decodeURIComponent(errorMsg).replace(/_/g, ' '),
                icon: 'error',
                confirmButtonColor: '#3085d6',
                confirmButtonText: 'Tutup'
            });
            window.history.replaceState(null, null, window.location.pathname);
        }

        function toggleModal(modalID) {
            const modal = document.getElementById(modalID);
            modal.classList.toggle('hidden');
        }

        function openAturModal(kelasId, namaKelas, angkatanId, taId, keterangan) {
            document.getElementById('aturKelasName').innerText = namaKelas;
            document.getElementById('aturForm').action = '/enrolment/edit/' + kelasId;
            document.getElementById('aturAngkatan').value = angkatanId || '';
            document.getElementById('aturTa').value = taId || '';
            document.getElementById('aturKet').value = keterangan || '';
            toggleModal('modalAturEnrolment');
        }

        function confirmReset(e, form) {
            e.preventDefault();
            Swal.fire({
                title: 'Kosongkan Pengaturan Kelas?', 
                text: "Semua data siswa dan guru yang tergabung di kelas ini akan dilepas. Pengaturan Angkatan dan TA akan di-reset.", 
                icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#ef4444', cancelButtonColor: '#64748b', confirmButtonText: 'Ya, Kosongkan!'
            }).then((result) => {
                if (result.isConfirmed) form.submit();
            });
        }
    </script>
</body>
</html>
