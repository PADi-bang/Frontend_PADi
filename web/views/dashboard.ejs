<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard - App_PADi</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#F8F9FA] flex">
    <aside class="w-64 h-screen bg-white border-r p-6 flex flex-col">
        <div class="text-2xl font-bold text-[#006652] mb-10 flex items-center gap-2">
            <div class="bg-[#006652] w-8 h-8 rounded-lg"></div> Portal
        </div>
        <nav class="flex-1 space-y-2">
            <a href="/dashboard" class="flex items-center gap-3 p-3 bg-[#006652] text-white rounded-lg shadow-md">Dashboard</a>
            <a href="/daftar-siswa" class="flex items-center gap-3 p-3 text-gray-500 hover:bg-gray-100 rounded-lg">Daftar Siswa</a>
            <a href="/daftar-guru" class="flex items-center gap-3 p-3 text-gray-500 hover:bg-gray-100 rounded-lg">Daftar Guru</a>
            <a href="/jadwal" class="flex items-center gap-3 p-3 text-gray-500 hover:bg-gray-100 rounded-lg">Jadwal</a>
        </nav>
        <div class="mt-auto border-t pt-4">
            <a href="/" class="text-red-500 font-medium">Log Out</a>
        </div>
    </aside>

    <main class="flex-1 p-10">
        <header class="flex justify-between items-center mb-10">
            <h2 class="text-2xl font-bold text-gray-800">Manajemen Akun</h2>
            <button class="bg-orange-500 text-white px-4 py-2 rounded-lg text-sm font-bold">+ Tambahkan User</button>
        </header>

        <div class="grid grid-cols-3 gap-6 mb-10">
            <div class="bg-white p-6 rounded-2xl shadow-sm border">
                <p class="text-gray-400 text-sm">SISWA</p>
                <h3 class="text-3xl font-bold">1,240</h3>
                <p class="text-green-500 text-xs mt-2">↑ 12% dari kehadiran lalu</p>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border">
                <p class="text-gray-400 text-sm">GURU</p>
                <h3 class="text-3xl font-bold">86</h3>
                <p class="text-gray-400 text-xs mt-2">Akun terverifikasi</p>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border">
                <p class="text-gray-400 text-sm">ADMIN</p>
                <h3 class="text-3xl font-bold">04</h3>
                <p class="text-gray-400 text-xs mt-2">Admin yang mengakses</p>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-gray-50 text-xs text-gray-400 uppercase">
                    <tr>
                        <th class="px-6 py-4">Profil Pengguna</th>
                        <th class="px-6 py-4">Role</th>
                        <th class="px-6 py-4">NIP / NIK</th>
                        <th class="px-6 py-4">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y text-sm">
                    <tr>
                        <td class="px-6 py-4">Sarah Wijaya</td>
                        <td class="px-6 py-4"><span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">TEACHER</span></td>
                        <td class="px-6 py-4">24235354</td>
                        <td class="px-6 py-4 text-green-500">● Aktif</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>