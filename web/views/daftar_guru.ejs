<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Daftar Guru - App_PADi</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#F8F9FA] flex">
    <aside class="w-64 h-screen bg-white border-r p-6 flex flex-col fixed">
        <div class="text-2xl font-bold text-[#006652] mb-10 flex items-center gap-2">
            <div class="bg-[#006652] w-8 h-8 rounded-lg"></div> Portal
        </div>
        <nav class="flex-1 space-y-2">
            <a href="/dashboard" class="flex items-center gap-3 p-3 text-gray-500 hover:bg-gray-100 rounded-lg">Dashboard</a>
            <a href="/daftar-siswa" class="flex items-center gap-3 p-3 text-gray-500 hover:bg-gray-100 rounded-lg">Daftar Siswa</a>
            <a href="/daftar-guru" class="flex items-center gap-3 p-3 bg-[#006652] text-white rounded-lg shadow-md">Daftar Guru</a>
            <a href="/jadwal" class="flex items-center gap-3 p-3 text-gray-500 hover:bg-gray-100 rounded-lg">Jadwal</a>
        </nav>
        <div class="mt-auto border-t pt-4 space-y-2">
            <a href="/" class="flex items-center gap-3 p-3 text-red-500 font-medium">Log Out</a>
        </div>
    </aside>

    <main class="flex-1 ml-64 p-10">
        <header class="flex justify-between items-center mb-8">
            <div>
                <h2 class="text-3xl font-bold text-gray-800">Manajemen Akun Guru</h2>
                <p class="text-gray-500 text-sm">Kelola data, akses, dan informasi pengajar aktif.</p>
            </div>
            <button class="bg-[#006652] text-white px-5 py-2.5 rounded-xl text-sm font-bold flex items-center gap-2">
                <span>+ Tambah Guru</span>
            </button>
        </header>

        <div class="grid grid-cols-3 gap-6 mb-8">
            <div class="bg-[#006652] text-white p-6 rounded-2xl shadow-sm flex justify-between items-center relative overflow-hidden">
                <div>
                    <p class="text-green-200 text-xs font-semibold uppercase">Total Pengajar</p>
                    <h3 class="text-4xl font-bold mt-1">128</h3>
                    <p class="text-green-200 text-[11px] mt-2">↗ +4 bulan ini</p>
                </div>
                <div class="text-4xl opacity-10 absolute right-4 bottom-4">👥</div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border flex justify-between items-center">
                <div>
                    <p class="text-gray-400 text-xs font-semibold uppercase">Akun Terverifikasi</p>
                    <h3 class="text-4xl font-bold mt-1">115</h3>
                    <p class="text-gray-400 text-[11px] mt-2">13 menunggu verifikasi</p>
                </div>
                <div class="bg-green-50 p-3 rounded-xl text-green-600 text-xl">✓</div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border flex justify-between items-center">
                <div>
                    <p class="text-gray-400 text-xs font-semibold uppercase">Departemen Aktif</p>
                    <h3 class="text-4xl font-bold mt-1">8</h3>
                    <p class="text-gray-400 text-[11px] mt-2">Tersebar di 46 kelas</p>
                </div>
                <div class="bg-orange-50 p-3 rounded-xl text-orange-600 text-xl">🏛</div>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border overflow-hidden">
            <div class="p-6 border-b flex justify-between items-center bg-white">
                <div class="relative w-80">
                    <input type="text" placeholder="Cari nama atau NIP..." class="w-full pl-10 pr-4 py-2 border rounded-xl text-sm focus:ring-[#006652] outline-none bg-gray-50/50">
                    <span class="absolute left-3 top-2.5 opacity-30">🔍</span>
                </div>
                <div>
                    <select class="border rounded-xl px-4 py-2 text-sm text-gray-500 outline-none bg-gray-50/50">
                        <option>Semua Departemen</option>
                    </select>
                </div>
            </div>

            <table class="w-full text-left border-collapse">
                <thead class="bg-gray-50 text-[10px] text-gray-400 uppercase tracking-wider font-bold">
                    <tr>
                        <th class="px-8 py-4">Profil</th>
                        <th class="px-6 py-4">NIP</th>
                        <th class="px-6 py-4">Departemen / Mapel</th>
                        <th class="px-6 py-4">Kelas</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y text-sm text-gray-600">
                    <tr class="hover:bg-gray-50/80 transition">
                        <td class="px-8 py-4 flex items-center gap-3">
                            <div class="w-9 h-9 bg-gray-200 rounded-full flex items-center justify-center font-bold text-gray-500">BS</div>
                            <div>
                                <p class="font-bold text-gray-800">Budi Santoso, S.Kom</p>
                                <p class="text-xs text-gray-400">budi.s@smk.edu</p>
                            </div>
                        </td>
                        <td class="px-6 py-4 font-mono text-xs">198503242010011005</td>
                        <td class="px-6 py-4 text-xs">
                            <p class="font-semibold text-gray-700">Rekayasa Perangkat Lunak</p>
                            <p class="text-gray-400">Pemrograman Web</p>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-col gap-1">
                                <span class="bg-blue-50 text-blue-600 px-2 py-0.5 rounded text-[10px] font-bold w-max">XII RPL 1</span>
                                <span class="bg-blue-50 text-blue-600 px-2 py-0.5 rounded text-[10px] font-bold w-max">XII RPL 2</span>
                            </div>
                        </td>
                        <td class="px-6 py-4"><span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-[10px] font-bold">Aktif</span></td>
                        <td class="px-6 py-4"></td>
                    </tr>
                    <tr class="hover:bg-gray-50/80 transition">
                        <td class="px-8 py-4 flex items-center gap-3">
                            <div class="w-9 h-9 bg-gray-200 rounded-full flex items-center justify-center font-bold text-gray-500">SR</div>
                            <div>
                                <p class="font-bold text-gray-800">Siti Rahmawati, M.Pd</p>
                                <p class="text-xs text-gray-400">siti.r@smk.edu</p>
                            </div>
                        </td>
                        <td class="px-6 py-4 font-mono text-xs">198207232009012003</td>
                        <td class="px-6 py-4 text-xs">
                            <p class="font-semibold text-gray-700">Mata Pelajaran Umum</p>
                            <p class="text-gray-400">Bahasa Inggris</p>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-col gap-1">
                                <span class="bg-blue-50 text-blue-600 px-2 py-0.5 rounded text-[10px] font-bold w-max">X TKJ 1</span>
                                <span class="bg-blue-50 text-blue-600 px-2 py-0.5 rounded text-[10px] font-bold w-max">XI MM 2</span>
                                <span class="text-[10px] text-gray-400 ml-1">+2</span>
                            </div>
                        </td>
                        <td class="px-6 py-4"><span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-[10px] font-bold">Aktif</span></td>
                        <td class="px-6 py-4"></td>
                    </tr>
                    <tr class="hover:bg-gray-50/80 transition">
                        <td class="px-8 py-4 flex items-center gap-3">
                            <div class="w-9 h-9 bg-gray-100 rounded-full flex items-center justify-center font-bold text-blue-600 text-xs">AF</div>
                            <div>
                                <p class="font-bold text-gray-800">Ahmad Fauzi, ST</p>
                                <p class="text-xs text-gray-400">ahmad.f@smk.edu</p>
                            </div>
                        </td>
                        <td class="px-6 py-4 font-mono text-xs">199101122023051002</td>
                        <td class="px-6 py-4 text-xs">
                            <p class="font-semibold text-gray-700">Teknik Komputer Jaringan</p>
                            <p class="text-gray-400">Administrasi Server</p>
                        </td>
                        <td class="px-6 py-4 text-xs text-gray-400 italic">Belum ditugaskan</td>
                        <td class="px-6 py-4"><span class="bg-orange-50 text-orange-600 px-3 py-1 rounded-full text-[10px] font-bold">★ Menunggu</span></td>
                        <td class="px-6 py-4"></td>
                    </tr>
                </tbody>
            </table>

            <div class="p-6 bg-white border-t flex justify-between items-center text-xs text-gray-400">
                <p>Menampilkan 1 sampai 10 dari 128 entri</p>
                <div class="flex gap-1.5">
                    <button class="px-3 py-1.5 rounded-lg border bg-[#006652] text-white font-bold">1</button>
                    <button class="px-3 py-1.5 rounded-lg border hover:bg-gray-50">2</button>
                    <button class="px-3 py-1.5 rounded-lg border hover:bg-gray-50">3</button>
                    <span>...</span>
                    <button class="px-3 py-1.5 rounded-lg border hover:bg-gray-50">13</button>
                </div>
            </div>
        </div>
    </main>
</body>
</html>