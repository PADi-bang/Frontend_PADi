<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Daftar Guru - App_PADi</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 flex font-sans">
    
    <aside class="w-64 h-screen bg-black text-gray-400 p-6 flex flex-col fixed rounded-r-3xl shadow-2xl z-20">
        <div class="text-3xl font-bold text-white mb-12 mt-4 tracking-widest pl-2">PADi</div>
        <nav class="flex-1 space-y-3">
            <a href="/dashboard" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">⊞</span> Dashboard
            </a>
            <a href="/daftar-siswa" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">👤</span> Daftar Siswa
            </a>
            <a href="/daftar-guru" class="flex items-center gap-4 p-3.5 bg-blue-600 text-white rounded-2xl shadow-lg shadow-blue-600/40 transition">
                <span class="text-lg">👨‍🏫</span> Daftar Guru
            </a>
            <a href="/jadwal" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">📅</span> Jadwal
            </a>
        </nav>
        <div class="mt-auto mb-4">
            <a href="/logout" class="flex justify-center items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 px-4 rounded-full transition shadow-lg shadow-blue-600/30">
                <span class="text-lg">⎋</span> LOGOUT
            </a>
        </div>
    </aside>

    <main class="flex-1 ml-64 p-8">
        
        <div class="bg-blue-600 rounded-3xl p-4 flex justify-between items-center text-white mb-8 shadow-lg shadow-blue-600/20">
            <form action="/daftar-guru" method="GET" class="relative w-96 ml-2">
                <span class="absolute left-4 top-2.5 opacity-50">🔍</span>
                <input type="text" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" placeholder="Cari nama guru, NIP, atau email..." class="w-full bg-blue-700/50 text-white placeholder-blue-200 border border-blue-500/50 rounded-full pl-12 pr-4 py-2 outline-none focus:ring-2 focus:ring-white/50 text-sm transition">
            </form>

            <div class="flex items-center gap-6 pr-4">
                <button onclick="toggleModal('modalTambahGuru')" class="bg-white text-blue-600 px-5 py-2 rounded-full text-xs font-bold shadow-md hover:bg-gray-100 transition">+ Tambah Guru</button>
                <div class="flex items-center gap-3 border-l border-blue-400/50 pl-6 cursor-pointer">
                    <span class="text-sm font-bold tracking-wide uppercase">Admin PADI</span>
                    <div class="w-9 h-9 bg-white rounded-full flex items-center justify-center text-blue-600 font-bold text-xs">AD</div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-3 gap-6 mb-8">
            <div class="bg-blue-600 text-white p-6 rounded-3xl shadow-lg shadow-blue-600/20 flex justify-between items-center relative overflow-hidden">
                <div>
                    <p class="text-blue-200 text-xs font-bold uppercase">Total Pengajar</p>
                    <h3 class="text-4xl font-bold mt-1"><%= gurus ? gurus.length : 0 %></h3>
                    <p class="text-blue-200 text-[11px] mt-2 font-semibold">Aktif di database</p>
                </div>
                <div class="text-5xl opacity-20 absolute right-4 bottom-4 font-black"><%= gurus ? gurus.length : 0 %></div>
            </div>
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex justify-between items-center">
                <div>
                    <p class="text-gray-400 text-xs font-bold uppercase">Akun Terverifikasi</p>
                    <h3 class="text-4xl font-bold text-gray-800 mt-1"><%= gurus ? gurus.length : 0 %></h3>
                    <p class="text-gray-400 text-[11px] mt-2 font-semibold">Sistem aktif sepenuhnya</p>
                </div>
                <div class="bg-blue-50 border border-blue-100 p-4 rounded-full text-xl text-blue-500">✓</div>
            </div>
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex justify-between items-center">
                <div>
                    <p class="text-gray-400 text-xs font-bold uppercase">Departemen Aktif</p>
                    <h3 class="text-4xl font-bold text-gray-800 mt-1">Belum</h3>
                    <p class="text-gray-400 text-[11px] mt-2 font-semibold">Tersedia</p>
                </div>
                <div class="bg-slate-100 border border-gray-200 p-4 rounded-full text-xl text-gray-500">🏛</div>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-6 border-b flex justify-end items-center bg-white">
                <select class="border rounded-xl px-4 py-2.5 text-sm text-gray-600 font-semibold outline-none focus:border-blue-600 bg-slate-50"><option>Semua Departemen</option></select>
            </div>

            <table class="w-full text-left">
                <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase tracking-wider font-bold">
                    <tr>
                        <th class="px-8 py-4">Profil</th>
                        <th class="px-6 py-4">NIP</th>
                        <th class="px-6 py-4">Departemen / Mapel</th>
                        <th class="px-6 py-4">Kelas Diampu</th>
                        <th class="px-6 py-4">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y text-sm text-gray-600">
                    <% if (typeof gurus !== 'undefined' && gurus.length > 0) { %>
                        <% gurus.forEach(function(user) { %>
                            <tr class="hover:bg-slate-50 transition cursor-pointer">
                                <td class="px-8 py-4 flex items-center gap-4">
                                    <div class="w-10 h-10 bg-slate-200 text-gray-500 rounded-full flex items-center justify-center font-bold text-xs">
                                        <%= user.guru && user.guru.namaLengkap ? user.guru.namaLengkap.substring(0, 2).toUpperCase() : 'U' %>
                                    </div>
                                    <div>
                                        <p class="font-bold text-gray-800"><%= user.guru ? user.guru.namaLengkap : 'Tanpa Nama' %></p>
                                        <p class="text-xs text-gray-400"><%= user.email %></p>
                                    </div>
                                </td>
                                <td class="px-6 py-4 font-mono text-xs text-gray-500"><%= user.guru ? user.guru.nip : '-' %></td>
                                <td class="px-6 py-4 text-xs">
                                    <p class="font-bold text-gray-700">Belum Diatur</p>
                                    <p class="text-gray-400 mt-0.5">-</p>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-wrap gap-2">
                                        <span class="bg-slate-100 border border-gray-200 text-gray-400 px-2 py-1 rounded text-[10px] font-bold">Belum ditugaskan</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4"><span class="bg-green-50 border border-green-100 text-green-600 px-3 py-1.5 rounded-full text-[10px] font-bold">● Aktif</span></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="px-8 py-8 text-center text-gray-500 font-bold">Tidak ada data guru ditemukan.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <div id="modalTambahGuru" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl relative transform transition-all">
            <button onclick="toggleModal('modalTambahGuru')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-2">Tambah Guru</h2>
            <p class="text-xs text-gray-500 mb-6">Buat akun pengajar dan daftarkan ke sistem.</p>
            
            <form action="/daftar-guru" method="POST" class="space-y-4">
                <div>
                    <label class="text-xs font-bold text-gray-700">Nama Lengkap (Beserta Gelar)</label>
                    <input type="text" name="namaLengkap" required class="w-full bg-slate-50 border border-gray-200 rounded-xl px-4 py-3 mt-1 text-sm outline-none focus:border-blue-500 focus:bg-white">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-xs font-bold text-gray-700">NIP</label>
                        <input type="text" name="nip" required class="w-full bg-slate-50 border border-gray-200 rounded-xl px-4 py-3 mt-1 text-sm outline-none focus:border-blue-500 focus:bg-white">
                    </div>
                    <div>
                        <label class="text-xs font-bold text-gray-700">Username Akun</label>
                        <input type="text" name="username" required class="w-full bg-slate-50 border border-gray-200 rounded-xl px-4 py-3 mt-1 text-sm outline-none focus:border-blue-500 focus:bg-white">
                    </div>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-700">Alamat Email</label>
                    <input type="email" name="email" required class="w-full bg-slate-50 border border-gray-200 rounded-xl px-4 py-3 mt-1 text-sm outline-none focus:border-blue-500 focus:bg-white">
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-700">Password</label>
                    <input type="password" name="password" required class="w-full bg-slate-50 border border-gray-200 rounded-xl px-4 py-3 mt-1 text-sm outline-none focus:border-blue-500 focus:bg-white">
                </div>
                <input type="hidden" name="sekolahId" value="1">
                
                <button type="submit" class="w-full bg-blue-600 text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-blue-700 shadow-lg shadow-blue-600/30 transition">Simpan Data Guru</button>
            </form>
        </div>
    </div>

    <script>
        function toggleModal(modalID) {
            const modal = document.getElementById(modalID);
            if(modal.classList.contains('hidden')) {
                modal.classList.remove('hidden');
            } else {
                modal.classList.add('hidden');
            }
        }
    </script>
</body>
</html>