<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Daftar Guru - App_PADi</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="icon" type="image/png" href="/favicon.png">


    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#006D5B',
                        'primary-dark': '#004A3F',
                        'primary-light': '#338A7B',
                    },
                    fontFamily: {
                        sans: ['Outfit', 'sans-serif'],
                    }
                }
            }
        }
    </script>

</head>
<body class="bg-slate-100 flex font-sans">
    
    <aside class="w-64 h-screen bg-[#00382E] text-white/70 p-6 flex flex-col fixed rounded-r-3xl shadow-2xl z-20">
        <div class="flex items-center gap-3 mb-12 mt-4 pl-2">
            <img src="/images/logo_padi.png" alt="Logo" class="w-10 h-10 object-contain drop-shadow-md">
            <span class="text-3xl font-black text-white tracking-widest">PADi</span>
        </div>
        <nav class="flex-1 space-y-3">
            <a href="/dashboard" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg> Dashboard
            </a>
            <a href="/daftar-siswa" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg> Daftar Siswa
            </a>
            <a href="/daftar-guru" class="flex items-center gap-4 p-3.5 bg-primary text-white rounded-2xl shadow-lg shadow-primary/40 transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg> Daftar Guru
            </a>
            <a href="/jadwal" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg> Jadwal
            </a>
            <a href="/master-data" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg> Master Data
            </a>
            <a href="/enrolment" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path></svg> Enrolment Kelas
            </a>
        </nav>
        <div class="mt-auto mb-4">
            <a href="/logout" class="flex justify-center items-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold py-3.5 px-4 rounded-full transition shadow-lg shadow-primary/30">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg> LOGOUT
            </a>
        </div>
    </aside>

    <main class="flex-1 ml-64 p-8">
        
        <div class="bg-primary rounded-3xl p-4 flex justify-between items-center text-white mb-8 shadow-lg shadow-primary/20">
            <form action="/daftar-guru" method="GET" class="relative w-96 ml-2">
                <span class="absolute left-4 top-2.5 opacity-50">🔍</span>
                <input type="text" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" placeholder="Cari nama guru, NIP, atau email..." class="w-full bg-primary-dark/50 text-white placeholder-blue-200 border border-primary-light/50 rounded-full pl-12 pr-4 py-2 outline-none focus:ring-2 focus:ring-white/50 text-sm transition">
            </form>

            <div class="flex items-center gap-6 pr-4">
                <button onclick="toggleModal('modalTambahGuru')" class="bg-white text-primary px-5 py-2 rounded-full text-xs font-bold shadow-md hover:bg-gray-100 transition">+ Tambah Guru</button>
                <div class="flex items-center gap-3 border-l border-primary-light/50 pl-6 cursor-pointer">
                    <span class="text-sm font-bold tracking-wide uppercase">Admin PADI</span>
                    <div class="w-9 h-9 bg-white rounded-full flex items-center justify-center text-primary font-bold text-xs">AD</div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-3 gap-6 mb-8">
            <div class="bg-primary text-white p-6 rounded-3xl shadow-lg shadow-primary/20 flex justify-between items-center relative overflow-hidden">
                <div>
                    <p class="text-white/70 text-xs font-bold uppercase">Total Pengajar</p>
                    <h3 class="text-4xl font-bold mt-1"><%= gurus ? gurus.length : 0 %></h3>
                </div>
                <div class="text-5xl opacity-20 absolute right-4 bottom-4 font-black"><%= gurus ? gurus.length : 0 %></div>
            </div>
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex justify-between items-center">
                <div>
                    <p class="text-gray-400 text-xs font-bold uppercase">Pengajar Aktif</p>
                    <h3 class="text-4xl font-bold text-gray-800 mt-1"><%= gurus ? gurus.length : 0 %></h3>
                </div>
<div class="bg-primary/10 border border-primary/20 p-4 rounded-full text-xl text-primary-light">✓</div>
            </div>
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex justify-between items-center">
                <div>
                    <p class="text-gray-400 text-[10px] font-bold uppercase leading-tight">Pengajar Cuti/Dinas/<br>Kegiatan Diluar Sekolah</p>
                    <h3 class="text-4xl font-bold text-gray-800 mt-1">0</h3>
                </div>
                <div class="bg-orange-50 border border-orange-100 p-4 rounded-full text-xl text-orange-500">🏢</div>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase tracking-wider font-bold">
                    <tr>
                        <th class="px-8 py-4">Profil</th>
                        <th class="px-6 py-4">NIP</th>
                        <th class="px-6 py-4">Kelas</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y text-sm text-gray-600">
                    <% if (typeof gurus !== 'undefined' && gurus.length > 0) { %>
                        <% gurus.forEach(function(user) { %>
                            <tr class="hover:bg-slate-50 transition">
                                <td class="px-8 py-4 flex items-center gap-4">
                                    <div class="w-10 h-10 bg-slate-200 text-gray-500 rounded-full flex items-center justify-center font-bold text-xs">
                                        <%= user.guru && user.guru.namaLengkap ? user.guru.namaLengkap.substring(0, 2).toUpperCase() : 'U' %>
                                    </div>
                                    <div>
                                        <p class="font-bold text-gray-800"><%= user.guru ? user.guru.namaLengkap : 'Tanpa Nama' %></p>
                                        <p class="text-xs text-gray-400"><%= user.email %></p>
                                    </div>
                                </td>
                                <td class="px-6 py-4 font-mono text-xs text-gray-500"><%= user.guru ? user.guru.nip : '-' %></td>
                                <td class="px-6 py-4">
                                    <% if (user.guru && user.guru.enrolmentGuru && user.guru.enrolmentGuru.length > 0) { %>
                                        <div class="flex flex-wrap gap-1">
                                            <% user.guru.enrolmentGuru.forEach(function(eg) { %>
                                                <span class="bg-indigo-50 border border-indigo-100 text-indigo-600 px-2 py-1 rounded text-[10px] font-bold"><%= eg.enrolmentKelas.masterKelas.namaKelas %></span>
                                            <% }); %>
                                        </div>
                                    <% } else { %>
                                        <span class="text-[10px] text-gray-400 italic">Belum diatur</span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4"><span class="bg-green-50 border border-green-100 text-green-600 px-3 py-1.5 rounded-full text-[10px] font-bold">🔴 Aktif</span></td>
                                <td class="px-6 py-4 flex justify-center gap-2">
<button onclick="bukaAturKelas('<%= user.id %>', '<%= user.guru ? user.guru.namaLengkap : '' %>', '<%= user.guru && user.guru.enrolmentGuru ? user.guru.enrolmentGuru.map(e => e.enrolmentKelasId).join(',') : '' %>')" class="bg-indigo-100 text-indigo-600 px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-indigo-200 transition">Atur Kelas</button>
                                    <button onclick="bukaEditGuru('<%= user.id %>', '<%= user.guru ? user.guru.namaLengkap : '' %>', '<%= user.guru ? user.guru.nip : '' %>', '<%= user.username %>', '<%= user.email %>')" class="bg-primary/20 text-primary px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-primary/30 transition">Edit</button>
                                    
                                    <form action="/daftar-guru/delete/<%= user.id %>" method="POST" class="inline" onsubmit="return confirmDelete(event, this);">
                                        <button type="submit" class="bg-red-100 text-red-600 px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-red-200 transition">Hapus</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="5" class="px-8 py-8 text-center text-gray-500 font-bold">Tidak ada data guru.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <div id="modalTambahGuru" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl relative">
            <button onclick="toggleModal('modalTambahGuru')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-6">Tambah Guru</h2>
            <form action="/daftar-guru" method="POST" class="space-y-4">
                <input type="text" name="namaLengkap" placeholder="Nama Lengkap" required class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light">
                <div class="grid grid-cols-2 gap-4">
                    <input type="text" name="nip" placeholder="NIP" required class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light">
                    <input type="text" name="username" placeholder="Username" required class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light">
                </div>
                <input type="email" name="email" placeholder="Email" required class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light">
                <input type="password" name="password" placeholder="Password" required class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light">
                <input type="hidden" name="sekolahId" value="1">
                <button type="submit" class="w-full bg-primary text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-primary-dark">Simpan Data</button>
            </form>
        </div>
    </div>

    <div id="modalEditGuru" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl relative">
            <button onclick="toggleModal('modalEditGuru')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-6">Edit Guru</h2>
            <form id="formEditGuru" method="POST" class="space-y-4">
                <input type="text" id="editNamaGuru" name="namaLengkap" required class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light">
                <div class="grid grid-cols-2 gap-4">
                    <input type="text" id="editNip" name="nip" required class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light">
                    <input type="text" id="editUsernameGuru" name="username" required class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light">
                </div>
                <input type="email" id="editEmailGuru" name="email" required class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light">
                <input type="password" name="password" placeholder="Kosongkan jika tidak ganti sandi" class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light">
                <button type="submit" class="w-full bg-primary text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-primary-dark">Update Data</button>
            </form>
        </div>
    </div>

    <div id="modalAturKelas" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl relative">
            <button onclick="toggleModal('modalAturKelas')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-2">Atur Kelas</h2>
            <p class="text-sm text-gray-500 mb-6">Pilih kelas yang diajar oleh <span id="aturKelasNama" class="font-bold text-gray-700"></span></p>
            
            <form id="formAturKelas" method="POST" class="space-y-4">
                <div class="max-h-60 overflow-y-auto border border-gray-100 rounded-xl p-4 bg-slate-50 space-y-2">
                    <% if (typeof enrolments !== 'undefined' && enrolments.length > 0) { %>
                        <% enrolments.forEach(function(kelas) { %>
                            <% if (kelas.enrolment) { %>
                                <label class="flex items-center gap-3 p-2 hover:bg-white rounded-lg cursor-pointer transition">
                                    <input type="checkbox" name="enrolmentKelasIds" value="<%= kelas.enrolment.id %>" id="chk_kelas_<%= kelas.enrolment.id %>" class="kelas-checkbox w-4 h-4 text-blue-600 rounded focus:ring-blue-500">
                                    <span class="text-sm font-bold text-gray-700"><%= kelas.masterKelas.namaKelas %></span>
                                </label>
                            <% } %>
                        <% }); %>
                    <% } else { %>
                        <p class="text-xs text-gray-400 text-center py-4">Belum ada kelas aktif. Silakan tambahkan di menu Enrolment Kelas.</p>
                    <% } %>
                </div>
                <button type="submit" class="w-full bg-indigo-600 text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-indigo-700">Simpan Kelas</button>
            </form>
        </div>
    </div>

    <script>
        function toggleModal(modalID) {
            const modal = document.getElementById(modalID);
            modal.classList.toggle('hidden');
        }

        function bukaAturKelas(userId, namaLengkap, enrolmentIdsStr) {
            document.getElementById('formAturKelas').action = '/daftar-guru/' + userId + '/kelas';
            document.getElementById('aturKelasNama').innerText = namaLengkap;
            
            document.querySelectorAll('.kelas-checkbox').forEach(cb => cb.checked = false);
            
            if (enrolmentIdsStr && enrolmentIdsStr.trim() !== '') {
                const ids = enrolmentIdsStr.split(',');
                ids.forEach(id => {
                    const cb = document.getElementById('chk_kelas_' + id.trim());
                    if (cb) cb.checked = true;
                });
            }
            
            toggleModal('modalAturKelas');
        }

        function bukaEditGuru(id, nama, nip, username, email) {
            document.getElementById('formEditGuru').action = '/daftar-guru/edit/' + id;
            document.getElementById('editNamaGuru').value = nama;
            document.getElementById('editNip').value = nip;
            document.getElementById('editUsernameGuru').value = username;
            document.getElementById('editEmailGuru').value = email;
            toggleModal('modalEditGuru');
        }

        function confirmDelete(e, form) {
            e.preventDefault();
            Swal.fire({
                title: 'Hapus Guru?', text: "Data ini tidak bisa dikembalikan!", icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#ef4444', cancelButtonColor: '#64748b', confirmButtonText: 'Ya, Hapus!'
            }).then((result) => {
                if (result.isConfirmed) form.submit();
            });
        }
    </script>

    

    


    </body>
</html>
