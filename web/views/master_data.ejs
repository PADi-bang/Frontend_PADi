<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Master Data - App_PADi</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-slate-100 flex font-sans">
    
    <aside class="w-64 h-screen bg-black text-gray-400 p-6 flex flex-col fixed rounded-r-3xl shadow-2xl z-20">
        <div class="text-3xl font-bold text-white mb-12 mt-4 tracking-widest pl-2">PADi</div>
        <nav class="flex-1 space-y-3">
            <a href="/dashboard" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">⊞</span> Dashboard
            </a>
            <a href="/daftar-siswa" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">👤</span> Daftar Siswa
            </a>
            <a href="/daftar-guru" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">👨‍🏫</span> Daftar Guru
            </a>
            <a href="/jadwal" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">📅</span> Jadwal
            </a>
            <a href="/master-data" class="flex items-center gap-4 p-3.5 bg-blue-600 text-white rounded-2xl shadow-lg shadow-blue-600/40 transition">
                <span class="text-lg">🗂️</span> Master Data
            </a>
            <a href="/enrolment" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">🎓</span> Enrolment Kelas
            </a>
        </nav>
        <div class="mt-auto mb-4">
            <a href="/logout" class="flex justify-center items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 px-4 rounded-full transition shadow-lg shadow-blue-600/30">
                <span class="text-lg">⎋</span> LOGOUT
            </a>
        </div>
    </aside>

    <main class="flex-1 ml-64 p-8">
        <div class="bg-blue-600 rounded-3xl p-4 flex justify-between items-center text-white mb-8 shadow-lg shadow-blue-600/20">
            <h1 class="text-2xl font-bold ml-4">Pengelolaan Master Data</h1>
            <div class="flex items-center gap-6 pr-4">
                <div class="flex items-center gap-3 border-l border-blue-400/50 pl-6 cursor-pointer">
                    <span class="text-sm font-bold tracking-wide uppercase">Admin PADI</span>
                    <div class="w-9 h-9 bg-white rounded-full flex items-center justify-center text-blue-600 font-bold text-xs">AD</div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 mb-8">
            <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">⚙️ Pengaturan Sistem</h2>
            <form action="/master-data/pengaturan" method="POST" class="flex flex-col gap-4">
                <div class="flex flex-wrap gap-4 items-end">
                    <div>
                        <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Mulai Ganjil</label>
                        <select name="ganjil" class="bg-slate-50 border rounded-xl px-4 py-2.5 text-sm outline-none focus:border-blue-500 min-w-[150px]">
                            <% for(let i=1; i<=12; i++) { %>
                                <option value="<%= i %>" <%= (typeof pengaturan !== 'undefined' && pengaturan.bulanGanjil === i) ? 'selected' : '' %>>Bulan ke-<%= i %></option>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Selesai Ganjil</label>
                        <select name="ganjilSelesai" class="bg-slate-50 border rounded-xl px-4 py-2.5 text-sm outline-none focus:border-blue-500 min-w-[150px]">
                            <% for(let i=1; i<=12; i++) { %>
                                <option value="<%= i %>" <%= (typeof pengaturan !== 'undefined' && pengaturan.bulanSelesaiGanjil === i) ? 'selected' : '' %>>Bulan ke-<%= i %></option>
                            <% } %>
                        </select>
                    </div>
                    <div class="ml-4">
                        <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Mulai Genap</label>
                        <select name="genap" class="bg-slate-50 border rounded-xl px-4 py-2.5 text-sm outline-none focus:border-blue-500 min-w-[150px]">
                            <% for(let i=1; i<=12; i++) { %>
                                <option value="<%= i %>" <%= (typeof pengaturan !== 'undefined' && pengaturan.bulanGenap === i) ? 'selected' : '' %>>Bulan ke-<%= i %></option>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Selesai Genap</label>
                        <select name="genapSelesai" class="bg-slate-50 border rounded-xl px-4 py-2.5 text-sm outline-none focus:border-blue-500 min-w-[150px]">
                            <% for(let i=1; i<=12; i++) { %>
                                <option value="<%= i %>" <%= (typeof pengaturan !== 'undefined' && pengaturan.bulanSelesaiGenap === i) ? 'selected' : '' %>>Bulan ke-<%= i %></option>
                            <% } %>
                        </select>
                    </div>
                    <button type="submit" class="bg-gray-800 text-white px-6 py-2.5 rounded-xl text-sm font-bold shadow-md hover:bg-black transition ml-auto">Simpan Pengaturan</button>
                </div>
            </form>
            <p class="text-[10px] text-gray-400 mt-3">* Pengaturan ini digunakan oleh sistem untuk otomatis mengubah status semester berjalan pada Tahun Akademik setiap tanggal 1.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            
            <!-- MASTER KELAS -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col h-[500px]">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">🏫 Master Kelas</h2>
                    <button onclick="toggleModal('modalTambahKelas')" class="bg-blue-100 text-blue-600 px-3 py-1.5 rounded-full text-xs font-bold shadow-md hover:bg-blue-200 transition">+ Tambah</button>
                </div>
                <div class="overflow-y-auto flex-1 border rounded-xl">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase tracking-wider font-bold sticky top-0">
                            <tr>
                                <th class="px-4 py-3">Nama Kelas</th>
                                <th class="px-4 py-3 text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y text-sm">
                            <% if (typeof kelas !== 'undefined' && kelas.length > 0) { %>
                                <% kelas.forEach(function(k) { %>
                                    <tr class="hover:bg-slate-50">
                                        <td class="px-4 py-3 font-bold text-gray-700"><%= k.namaKelas %></td>
                                        <td class="px-4 py-3 text-center">
                                            <form action="/master-data/kelas/delete/<%= k.id %>" method="POST" onsubmit="return confirmDelete(event, this, 'Kelas ini akan dihapus permanen!');">
                                                <button type="submit" class="bg-red-100 text-red-600 px-2 py-1 rounded-md text-xs font-bold hover:bg-red-200">Hapus</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="2" class="px-4 py-6 text-center text-gray-500 font-bold text-xs">Belum ada data.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- MASTER ANGKATAN -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col h-[500px]">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">🎓 Master Angkatan</h2>
                    <button onclick="toggleModal('modalTambahAngkatan')" class="bg-blue-100 text-blue-600 px-3 py-1.5 rounded-full text-xs font-bold shadow-md hover:bg-blue-200 transition">+ Tambah</button>
                </div>
                <div class="overflow-y-auto flex-1 border rounded-xl">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase tracking-wider font-bold sticky top-0">
                            <tr>
                                <th class="px-4 py-3">Angkatan</th>
                                <th class="px-4 py-3 text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y text-sm">
                            <% if (typeof angkatan !== 'undefined' && angkatan.length > 0) { %>
                                <% angkatan.forEach(function(a) { %>
                                    <tr class="hover:bg-slate-50">
                                        <td class="px-4 py-3 font-bold text-gray-700"><%= a.nomorAngkatan %></td>
                                        <td class="px-4 py-3 text-center">
                                            <form action="/master-data/angkatan/delete/<%= a.id %>" method="POST" onsubmit="return confirmDelete(event, this, 'Angkatan ini akan dihapus permanen!');">
                                                <button type="submit" class="bg-red-100 text-red-600 px-2 py-1 rounded-md text-xs font-bold hover:bg-red-200">Hapus</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="2" class="px-4 py-6 text-center text-gray-500 font-bold text-xs">Belum ada data.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- MASTER TAHUN AKADEMIK -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col h-[500px]">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">🗓️ Tahun Akademik</h2>
                    <button onclick="toggleModal('modalTambahTA')" class="bg-blue-100 text-blue-600 px-3 py-1.5 rounded-full text-xs font-bold shadow-md hover:bg-blue-200 transition">+ Tambah</button>
                </div>
                <div class="overflow-y-auto flex-1 border rounded-xl">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase tracking-wider font-bold sticky top-0">
                            <tr>
                                <th class="px-4 py-3">Periode</th>
                                <th class="px-4 py-3 text-center">Status</th>
                                <th class="px-4 py-3 text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y text-sm">
                            <% if (typeof tahunAkademik !== 'undefined' && tahunAkademik.length > 0) { %>
                                <% tahunAkademik.forEach(function(ta) { %>
                                    <tr class="hover:bg-slate-50">
                                        <td class="px-4 py-3 font-bold text-gray-700"><%= ta.tahunAjaran %></td>
                                        <td class="px-4 py-3 text-center">
                                            <% if(ta.isActive) { %>
                                                <form action="/master-data/tahun-akademik/activate/<%= ta.id %>" method="POST" class="inline">
                                                    <button type="submit" class="bg-green-100 text-green-600 px-2 py-1 rounded-md text-[10px] font-bold hover:bg-green-200">Aktif</button>
                                                </form>
                                            <% } else { %>
                                                <form action="/master-data/tahun-akademik/activate/<%= ta.id %>" method="POST" class="inline">
                                                    <button type="submit" class="bg-gray-100 text-gray-500 px-2 py-1 rounded-md text-[10px] font-bold hover:bg-gray-200">Nonaktif</button>
                                                </form>
                                            <% } %>
                                        </td>
                                        <td class="px-4 py-3 text-center">
                                            <form action="/master-data/tahun-akademik/delete/<%= ta.id %>" method="POST" onsubmit="return confirmDelete(event, this, 'Tahun akademik ini akan dihapus!');">
                                                <button type="submit" class="bg-red-100 text-red-600 px-2 py-1 rounded-md text-[10px] font-bold hover:bg-red-200">Hapus</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="3" class="px-4 py-6 text-center text-gray-500 font-bold text-xs">Belum ada data.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

    <!-- MODAL TAMBAH KELAS -->
    <div id="modalTambahKelas" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-sm shadow-2xl relative">
            <button onclick="toggleModal('modalTambahKelas')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-6">Tambah Kelas</h2>
            <form action="/master-data/kelas" method="POST" class="space-y-4">
                <div class="flex gap-2">
                    <select name="prefix" required class="bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-blue-500 w-1/3 text-center appearance-none cursor-pointer">
                        <option value="X">X</option>
                        <option value="XI">XI</option>
                        <option value="XII">XII</option>
                    </select>
                    <input type="text" name="namaKelasAkhiran" placeholder="Jurusan & Urutan (Contoh: PPLG 1)" required class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-blue-500">
                </div>
                <button type="submit" class="w-full bg-blue-600 text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-blue-700">Simpan Kelas</button>
            </form>
        </div>
    </div>

    <!-- MODAL TAMBAH ANGKATAN -->
    <div id="modalTambahAngkatan" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-sm shadow-2xl relative">
            <button onclick="toggleModal('modalTambahAngkatan')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-6">Tambah Angkatan</h2>
            <form action="/master-data/angkatan" method="POST" class="space-y-4">
                <input type="text" name="nomorAngkatan" placeholder="Angkatan (Contoh: 2023)" required class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-blue-500">
                <button type="submit" class="w-full bg-blue-600 text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-blue-700">Simpan Angkatan</button>
            </form>
        </div>
    </div>

    <!-- MODAL TAMBAH TAHUN AKADEMIK -->
    <div id="modalTambahTA" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-sm shadow-2xl relative">
            <button onclick="toggleModal('modalTambahTA')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-6">Tambah Tahun Akademik</h2>
            <form action="/master-data/tahun-akademik" method="POST" class="space-y-4">
                <input type="text" name="tahunAjaran" placeholder="Tahun Ajaran (Contoh: 2023/2024)" required class="w-full bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-blue-500">
                <div class="flex items-center gap-2 pl-2">
                    <input type="checkbox" name="isActive" value="true" id="isActiveCheck" class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500">
                    <label for="isActiveCheck" class="text-sm font-medium text-gray-700">Set sebagai Aktif</label>
                </div>
                <button type="submit" class="w-full bg-blue-600 text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-blue-700">Simpan TA</button>
            </form>
        </div>
    </div>

    <script>
        // Cek pesan error dari URL
        const urlParams = new URLSearchParams(window.location.search);
        const errorMsg = urlParams.get('error');
        if (errorMsg) {
            Swal.fire({
                title: 'Error!',
                text: decodeURIComponent(errorMsg).replace(/_/g, ' '),
                icon: 'error',
                confirmButtonColor: '#3085d6',
                confirmButtonText: 'Tutup'
            });
            // Hapus query string error
            window.history.replaceState(null, null, window.location.pathname);
        }

        function toggleModal(modalID) {
            const modal = document.getElementById(modalID);
            modal.classList.toggle('hidden');
        }

        function confirmDelete(e, form, text) {
            e.preventDefault();
            Swal.fire({
                title: 'Hapus Data?', text: text, icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#ef4444', cancelButtonColor: '#64748b', confirmButtonText: 'Ya, Hapus!'
            }).then((result) => {
                if (result.isConfirmed) form.submit();
            });
        }
    </script>

    

    


    </body>
</html>
