<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Daftar Siswa - App_PADi</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 flex font-sans">
    
    <aside class="w-64 h-screen bg-black text-gray-400 p-6 flex flex-col fixed rounded-r-3xl shadow-2xl z-20">
        <div class="text-3xl font-bold text-white mb-12 mt-4 tracking-widest pl-2">LOGO</div>
        <nav class="flex-1 space-y-3">
            <a href="/dashboard" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">⊞</span> Dashboard
            </a>
            <a href="/daftar-siswa" class="flex items-center gap-4 p-3.5 bg-blue-600 text-white rounded-2xl shadow-lg shadow-blue-600/40 transition">
                <span class="text-lg">👤</span> Daftar Siswa
            </a>
            <a href="/daftar-guru" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">👨‍🏫</span> Daftar Guru
            </a>
            <a href="/jadwal" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">📅</span> Jadwal
            </a>
        </nav>
        <div class="mt-auto mb-4">
            <a href="/logout" class="flex justify-center items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 px-4 rounded-full transition shadow-lg shadow-blue-600/30">
                <span class="text-lg">⎋</span> LOGOUT
            </a>
        </div>
    </aside>

    <main class="flex-1 ml-64 p-8">
        
        <div class="bg-blue-600 rounded-3xl p-4 flex justify-between items-center text-white mb-8 shadow-lg shadow-blue-600/20">
            <div class="relative w-96 ml-2">
                <span class="absolute left-4 top-2.5 opacity-50">🔍</span>
                <input type="text" placeholder="Search student..." class="w-full bg-blue-700/50 text-white placeholder-blue-200 border border-blue-500/50 rounded-full pl-12 pr-4 py-2 outline-none focus:ring-2 focus:ring-white/50 text-sm transition">
            </div>
            <div class="flex items-center gap-6 pr-4">
                <button class="bg-white text-blue-600 px-5 py-2 rounded-full text-xs font-bold shadow-md hover:bg-gray-100 transition">+ Tambah Siswa</button>
                <div class="flex items-center gap-3 border-l border-blue-400/50 pl-6 cursor-pointer">
                    <span class="text-sm font-bold tracking-wide uppercase">Admin PADI</span>
                    <div class="w-9 h-9 bg-white rounded-full flex items-center justify-center text-blue-600 font-bold text-xs">AD</div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-3 gap-6 mb-8">
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex justify-between items-center">
                <div>
                    <p class="text-gray-400 text-xs font-bold uppercase">Total Siswa</p>
                    <h3 class="text-3xl font-bold text-gray-800 mt-1">1,248</h3>
                </div>
                <div class="bg-slate-100 border p-4 rounded-full text-2xl">👥</div>
            </div>
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex justify-between items-center">
                <div>
                    <p class="text-gray-400 text-xs font-bold uppercase">Siswa Aktif</p>
                    <h3 class="text-3xl font-bold text-gray-800 mt-1">1,190</h3>
                </div>
                <div class="bg-green-50 border border-green-100 p-4 rounded-full text-2xl text-green-500">✅</div>
            </div>
            <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex justify-between items-center">
                <div>
                    <p class="text-gray-400 text-xs font-bold uppercase">Dalam Izin</p>
                    <h3 class="text-3xl font-bold text-gray-800 mt-1">58</h3>
                </div>
                <div class="bg-orange-50 border border-orange-100 p-4 rounded-full text-2xl text-orange-500">🌙</div>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-6 border-b flex justify-between items-center bg-white">
                <div class="flex gap-3">
                    <select class="border rounded-xl px-4 py-2.5 text-sm text-gray-600 font-semibold outline-none focus:border-blue-600"><option>Semua Tahun</option></select>
                    <select class="border rounded-xl px-4 py-2.5 text-sm text-gray-600 font-semibold outline-none focus:border-blue-600"><option>Semua Kelas</option></select>
                </div>
            </div>

            <table class="w-full text-left">
                <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase tracking-wider font-bold">
                    <tr>
                        <th class="px-8 py-4">Siswa</th>
                        <th class="px-6 py-4">NIS</th>
                        <th class="px-6 py-4">Kelas</th>
                        <th class="px-6 py-4">Kehadiran</th>
                        <th class="px-6 py-4">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y text-sm">
                    <tr class="hover:bg-slate-50 transition cursor-pointer">
                        <td class="px-8 py-4 flex items-center gap-4">
                            <div class="w-10 h-10 bg-blue-100 text-blue-600 font-bold rounded-full flex items-center justify-center">BS</div>
                            <div>
                                <p class="font-bold text-gray-800">Budi Santoso</p>
                                <p class="text-xs text-gray-400">budisantoso@sekolah.edu</p>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-gray-500 font-mono text-xs">21221001</td>
                        <td class="px-6 py-4"><span class="bg-slate-100 border text-gray-600 px-3 py-1.5 rounded-lg text-[10px] font-bold">XII RPL 1</span></td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <span class="font-bold text-gray-800 text-xs w-8">98%</span>
                                <div class="w-20 h-1.5 bg-gray-100 rounded-full overflow-hidden"><div class="bg-blue-600 h-full w-[98%]"></div></div>
                            </div>
                        </td>
                        <td class="px-6 py-4"><span class="text-green-500 font-bold text-xs flex items-center gap-1">● Aktif</span></td>
                    </tr>
                    <tr class="hover:bg-slate-50 transition cursor-pointer">
                        <td class="px-8 py-4 flex items-center gap-4">
                            <div class="w-10 h-10 bg-purple-100 text-purple-600 font-bold rounded-full flex items-center justify-center">SR</div>
                            <div>
                                <p class="font-bold text-gray-800">Siti Rahmawati</p>
                                <p class="text-xs text-gray-400">sitirahma@sekolah.edu</p>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-gray-500 font-mono text-xs">21221045</td>
                        <td class="px-6 py-4"><span class="bg-slate-100 border text-gray-600 px-3 py-1.5 rounded-lg text-[10px] font-bold">X TKJ 2</span></td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <span class="font-bold text-gray-800 text-xs w-8">85%</span>
                                <div class="w-20 h-1.5 bg-gray-100 rounded-full overflow-hidden"><div class="bg-orange-500 h-full w-[85%]"></div></div>
                            </div>
                        </td>
                        <td class="px-6 py-4"><span class="text-orange-500 font-bold text-xs flex items-center gap-1">● Peringatan</span></td>
                    </tr>
                </tbody>
            </table>
            <div class="p-6 border-t flex justify-between items-center text-xs text-gray-400">
                <p class="font-semibold">Menampilkan 10 dari 1,248 siswa</p>
                <div class="flex gap-2">
                    <button class="px-3.5 py-2 rounded-lg bg-blue-600 text-white font-bold shadow-md shadow-blue-600/30">1</button>
                    <button class="px-3.5 py-2 rounded-lg border hover:bg-slate-50 font-bold text-gray-600">2</button>
                    <button class="px-3.5 py-2 rounded-lg border hover:bg-slate-50 font-bold text-gray-600">3</button>
                    <span class="px-2 py-2">...</span>
                </div>
            </div>
        </div>
    </main>
</body>
</html>