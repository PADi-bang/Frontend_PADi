<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Pengaturan Waktu - App_PADi</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .drag-over { border: 2px dashed #2563eb; background-color: #eff6ff; }
    </style>
</head>
<body class="bg-slate-100 flex font-sans">
    
    <aside class="w-64 h-screen bg-black text-gray-400 p-6 flex flex-col fixed rounded-r-3xl shadow-2xl z-20">
        <div class="text-3xl font-bold text-white mb-12 mt-4 tracking-widest pl-2">PADI</div>
        <nav class="flex-1 space-y-3">
            <a href="/dashboard" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">⊞</span> Dashboard
            </a>
            <a href="/daftar-siswa" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">👤</span> Daftar Siswa
            </a>
            <a href="/daftar-guru" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">👨‍🏫</span> Daftar Guru
            </a>
            <a href="/jadwal" class="flex items-center gap-4 p-3.5 bg-blue-600 text-white rounded-2xl shadow-lg shadow-blue-600/40 transition">
                <span class="text-lg">📅</span> Jadwal
            </a>
        </nav>
        <div class="mt-auto mb-4">
            <a href="/logout" class="flex justify-center items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 px-4 rounded-full transition shadow-lg shadow-blue-600/30">
                <span class="text-lg">⎋</span> LOGOUT
            </a>
        </div>
    </aside>

    <main class="flex-1 ml-64 p-8 flex gap-8">
        <div class="flex-1 space-y-8">
            
            <div class="bg-blue-600 rounded-3xl p-4 flex justify-between items-center text-white shadow-lg shadow-blue-600/20">
                <div class="relative w-96 ml-2">
                    <span class="absolute left-4 top-2.5 opacity-50">🔍</span>
                    <input type="text" placeholder="Search..." class="w-full bg-blue-700/50 text-white placeholder-blue-200 border border-blue-500/50 rounded-full pl-12 pr-4 py-2 outline-none focus:ring-2 focus:ring-white/50 text-sm transition">
                </div>
                <div class="flex items-center gap-6 pr-4">
                    <div class="flex items-center gap-3 border-l border-blue-400/50 pl-6 cursor-pointer">
                        <span class="text-sm font-bold tracking-wide uppercase">Admin PADI</span>
                        <div class="w-9 h-9 bg-white rounded-full flex items-center justify-center text-blue-600 font-bold text-xs">AD</div>
                    </div>
                </div>
            </div>

            <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 flex justify-between items-center">
                <div>
                    <h2 class="text-2xl font-bold text-gray-800 mb-2">Pengaturan Waktu</h2>
                    <p class="text-gray-500 text-sm max-w-xl">Rancang shift yang selaras dengan jam pelajaran siswa dan jadwal standar.</p>
                </div>
                <button onclick="openModal()" class="bg-blue-600 text-white px-6 py-3 rounded-xl text-sm font-bold shadow-lg shadow-blue-600/30 hover:bg-blue-700 transition cursor-pointer">
                    + Buat Jadwal
                </button>
            </div>

            <div class="space-y-4">
                <h3 class="text-gray-800 font-bold text-sm tracking-wide uppercase ml-2">Jadwal Aktif</h3>

                <% if (typeof jadwalList !== 'undefined' && jadwalList && jadwalList.length > 0) { %>
                    <% jadwalList.forEach(jadwal => { 
                        const formatTime = (isoString) => {
                            if(!isoString) return '';
                            const d = new Date(isoString);
                            return d.toLocaleTimeString('id-ID', {hour: '2-digit', minute: '2-digit', timeZone: 'UTC'});
                        };
                    %>
                    <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm flex justify-between items-center hover:shadow-md transition drop-zone cursor-pointer" data-jadwal-id="<%= jadwal.id %>" onclick="showParams('<%= formatTime(jadwal.jamMasukStart) %>', '<%= formatTime(jadwal.jamMasukFinish) %>', '<%= formatTime(jadwal.jamPulang) %>')">
                        <div class="flex items-center gap-5">
                            <div class="bg-blue-50 border border-blue-100 p-4 rounded-full text-blue-600 font-bold text-sm">JS</div>
                            <div>
                                <h4 class="font-bold text-gray-800"><%= jadwal.namaJadwal %></h4>
                                <p class="text-xs text-gray-500 mt-1 font-semibold">
                                    <% if(jadwal.tanggal) { %>📅 <%= jadwal.tanggal.split('T')[0] %> | <% } %>
                                    🕒 <%= formatTime(jadwal.jamMasukStart) %> - <%= formatTime(jadwal.jamPulang) %> &nbsp;•&nbsp; 👥 <%= jadwal.kelas ? jadwal.kelas.length : 0 %> Kelas
                                </p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="flex flex-wrap max-w-[150px] gap-2 justify-end">
                                <% if (jadwal.kelas && jadwal.kelas.length > 0) { %>
                                    <% jadwal.kelas.forEach(k => { %>
                                        <div class="bg-slate-100 border text-gray-600 px-2.5 py-1 rounded-lg text-[10px] font-bold"><%= k.namaKelas %></div>
                                    <% }) %>
                                <% } %>
                            </div>
                            <button onclick="editJadwal('<%= jadwal.id %>', '<%= jadwal.namaJadwal %>', '<%= jadwal.hari %>', '<%= jadwal.tanggal ? jadwal.tanggal.split('T')[0] : '' %>', '<%= jadwal.jamMasukStart ? jadwal.jamMasukStart.substring(11, 16) : '' %>', '<%= jadwal.jamMasukFinish ? jadwal.jamMasukFinish.substring(11, 16) : '' %>', '<%= jadwal.jamPulang ? jadwal.jamPulang.substring(11, 16) : '' %>')" class="text-blue-500 hover:text-blue-700 ml-3" title="Edit">✏️</button>
                            <button onclick="hapusJadwal('<%= jadwal.id %>')" class="text-red-500 hover:text-red-700" title="Hapus">🗑️</button>
                        </div>
                    </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-sm text-gray-500 bg-white p-6 rounded-3xl border border-gray-100 text-center font-semibold">Belum ada jadwal. Silakan buat jadwal baru.</p>
                <% } %>
            </div>

            <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="font-bold text-gray-800 text-sm">Parameter Waktu</h3>
                    <span class="bg-blue-50 border border-blue-100 text-blue-600 px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-wider">Pilih Jadwal</span>
                </div>

                <div class="grid grid-cols-3 gap-6">
                    <div class="border rounded-2xl p-5 bg-slate-50">
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Check-In</p>
                        <input type="text" id="param-checkin" value="--" readonly class="font-bold text-gray-800 text-xl bg-transparent outline-none w-full mt-2">
                    </div>
                    <div class="border rounded-2xl p-5 bg-orange-50/50 border-orange-100">
                        <p class="text-[10px] text-orange-400 font-bold uppercase tracking-widest">Batas Terlambat</p>
                        <input type="text" id="param-late" value="--" readonly class="font-bold text-orange-600 text-xl bg-transparent outline-none w-full mt-2">
                    </div>
                    <div class="border rounded-2xl p-5 bg-slate-50">
                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Checkout</p>
                        <input type="text" id="param-checkout" value="--" readonly class="font-bold text-gray-800 text-xl bg-transparent outline-none w-full mt-2">
                    </div>
                </div>
            </div>
        </div>

        <div class="w-80 space-y-6 pt-24">
            <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm h-[500px] overflow-y-auto">
                <h3 class="font-bold text-gray-800 text-sm uppercase tracking-wide">Belum Terjadwal</h3>
                <p class="text-xs text-gray-400 mt-1 mb-6 font-semibold">Drag & drop kelas ke jadwal aktif</p>
                
                <% const unassignedKelas = (typeof kelasList !== 'undefined' && kelasList) ? kelasList.filter(k => !k.jadwalAbsensi || k.jadwalAbsensi.length === 0) : []; %>
                
                <% unassignedKelas.forEach(k => { %>
                <div class="draggable mb-3 border rounded-2xl p-4 flex justify-between items-center bg-slate-50 hover:bg-white hover:border-blue-300 transition cursor-grab shadow-sm" draggable="true" data-kelas-id="<%= k.id %>">
                    <div class="flex items-center gap-3">
                        <span class="text-blue-500 bg-blue-50 p-2 rounded-xl text-xs">🏫</span>
                        <p class="font-bold text-gray-700 text-sm"><%= k.namaKelas %></p>
                    </div>
                    <span class="text-gray-300 text-xs">⣿</span>
                </div>
                <% }) %>
            </div>
        </div>

        <div id="jadwalModal" class="fixed inset-0 bg-black/60 hidden flex justify-center items-center z-50 backdrop-blur-sm">
            <div class="bg-white p-8 rounded-3xl w-[500px] shadow-2xl">
                <h3 id="modalTitle" class="text-2xl font-bold mb-6 text-gray-800">Buat Jadwal Baru</h3>
                <form id="formJadwal" class="space-y-5">
                    <input type="hidden" id="jadwalId" name="id">
                    <div>
                        <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-wide">Nama Jadwal / Shift</label>
                        <input type="text" id="inputNama" name="namaJadwal" required placeholder="Contoh: Waktu Pembelajaran Pagi" class="w-full bg-slate-50 border border-gray-200 p-3.5 rounded-xl text-sm font-semibold outline-none focus:border-blue-600 focus:bg-white transition">
                    </div>
                    <div class="flex gap-5">
                        <div class="flex-1">
                            <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-wide">Hari Beroperasi</label>
                            <select id="inputHari" name="hari" class="w-full bg-slate-50 border border-gray-200 p-3.5 rounded-xl text-sm font-semibold outline-none focus:border-blue-600 focus:bg-white transition">
                                <option value="Senin-Jumat">Senin - Jumat</option>
                                <option value="Senin">Senin</option>
                                <option value="Selasa">Selasa</option>
                                <option value="Rabu">Rabu</option>
                                <option value="Kamis">Kamis</option>
                                <option value="Jumat">Jumat</option>
                                <option value="Sabtu">Sabtu</option>
                                <option value="Minggu">Minggu</option>
                            </select>
                        </div>
                        <div class="flex-1">
                            <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-wide">Tanggal</label>
                            <input type="date" id="inputTanggal" name="tanggal" class="w-full bg-slate-50 border border-gray-200 p-3.5 rounded-xl text-sm font-semibold outline-none focus:border-blue-600 focus:bg-white transition">
                        </div>
                    </div>
                    <div class="flex gap-5">
                        <div class="flex-1">
                            <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-wide">Check-In</label>
                            <input type="time" id="inputJamMasukStart" name="jamMasukStart" required class="w-full bg-slate-50 border border-gray-200 p-3.5 rounded-xl text-sm font-semibold outline-none focus:border-blue-600 focus:bg-white transition">
                        </div>
                        <div class="flex-1">
                            <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-wide">Batas Terlambat</label>
                            <input type="time" id="inputJamMasukFinish" name="jamMasukFinish" required class="w-full bg-slate-50 border border-gray-200 p-3.5 rounded-xl text-sm font-semibold outline-none focus:border-blue-600 focus:bg-white transition">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-wide">Check-Out (Pulang)</label>
                        <input type="time" id="inputJamPulang" name="jamPulang" required class="w-full bg-slate-50 border border-gray-200 p-3.5 rounded-xl text-sm font-semibold outline-none focus:border-blue-600 focus:bg-white transition">
                    </div>
                    
                    <div id="kelolaKelasContainer" class="hidden border-t border-gray-100 pt-6 mt-6">
                        <h4 class="text-sm font-bold text-gray-800 mb-4 uppercase tracking-wide">Kelola Kelas (Khusus Edit)</h4>
                        
                        <div class="mb-4">
                            <label class="block text-[10px] font-bold text-gray-400 mb-2 uppercase tracking-widest">Kelas Terdaftar</label>
                            <div id="kelasTerdaftarList" class="flex flex-wrap gap-2">
                                <!-- Diisi lewat JS -->
                            </div>
                        </div>
                        
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 mb-2 uppercase tracking-widest">Tambah Kelas</label>
                            <div class="flex gap-3">
                                <select id="selectKelasBaru" class="flex-1 bg-slate-50 border border-gray-200 p-3 rounded-xl text-sm font-semibold outline-none focus:border-blue-600 focus:bg-white transition">
                                    <option value="">-- Pilih Kelas Belum Terjadwal --</option>
                                </select>
                                <button type="button" onclick="assignKelasModal()" class="bg-blue-600 text-white px-5 py-3 rounded-xl text-sm font-bold shadow-md hover:bg-blue-700 transition cursor-pointer">Tambah</button>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end gap-3 pt-6 border-t mt-6">
                        <button type="button" onclick="closeModal()" class="px-6 py-3 text-sm text-gray-500 font-bold hover:bg-gray-100 rounded-xl transition cursor-pointer">Batal</button>
                        <button type="submit" class="bg-blue-600 text-white px-8 py-3 rounded-xl text-sm font-bold shadow-lg hover:bg-blue-700 transition cursor-pointer">Simpan Jadwal</button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <script>
        const modal = document.getElementById('jadwalModal');
        const form = document.getElementById('formJadwal');
        const modalTitle = document.getElementById('modalTitle');
        
        const dataServer = <%- JSON.stringify({ 
            jadwalList: typeof jadwalList !== 'undefined' ? jadwalList : [], 
            kelasList: typeof kelasList !== 'undefined' ? kelasList : [] 
        }) %>;

        function openModal() { 
            form.reset();
            document.getElementById('jadwalId').value = '';
            modalTitle.textContent = 'Buat Jadwal Baru';
            document.getElementById('kelolaKelasContainer').classList.add('hidden');
            modal.classList.remove('hidden'); 
        }

        function closeModal() { modal.classList.add('hidden'); }

        function editJadwal(id, nama, hari, tanggal, masuk, batas, pulang) {
            event.stopPropagation();
            document.getElementById('jadwalId').value = id;
            document.getElementById('inputNama').value = nama;
            document.getElementById('inputHari').value = hari;
            document.getElementById('inputTanggal').value = tanggal;
            document.getElementById('inputJamMasukStart').value = masuk;
            document.getElementById('inputJamMasukFinish').value = batas;
            document.getElementById('inputJamPulang').value = pulang;
            modalTitle.textContent = 'Edit Jadwal';
            
            document.getElementById('kelolaKelasContainer').classList.remove('hidden');
            
            const jadwalData = dataServer.jadwalList.find(j => j.id == id);
            const containerTerdaftar = document.getElementById('kelasTerdaftarList');
            containerTerdaftar.innerHTML = '';
            if(jadwalData && jadwalData.kelas && jadwalData.kelas.length > 0) {
                jadwalData.kelas.forEach(k => {
                    containerTerdaftar.innerHTML += `
                        <div class="bg-slate-100 border text-gray-600 px-3 py-1.5 rounded-lg text-xs font-bold flex items-center gap-2">
                            ${k.namaKelas}
                            <button type="button" onclick="unassignKelasModal('${jadwalData.id}', '${k.id}')" class="text-red-500 hover:text-red-700 font-bold ml-1 text-sm" title="Hapus Kelas">×</button>
                        </div>
                    `;
                });
            } else {
                containerTerdaftar.innerHTML = '<span class="text-xs text-gray-400 font-semibold">Belum ada kelas yang terdaftar</span>';
            }
            
            const selectBaru = document.getElementById('selectKelasBaru');
            selectBaru.innerHTML = '<option value="">-- Pilih Kelas Belum Terjadwal --</option>';
            const unassigned = dataServer.kelasList.filter(k => !k.jadwalAbsensi || k.jadwalAbsensi.length === 0);
            unassigned.forEach(k => {
                selectBaru.innerHTML += `<option value="${k.id}">${k.namaKelas}</option>`;
            });

            modal.classList.remove('hidden');
        }

        async function unassignKelasModal(jadwalId, kelasId) {
            if(!confirm("Hapus kelas ini dari jadwal?")) return;
            try {
                const res = await fetch(`http://localhost:3000/api/jadwal/${jadwalId}/unassign`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ kelasId })
                });
                if(res.ok) window.location.reload();
                else alert('Gagal membatalkan kelas dari jadwal');
            } catch(err) {
                alert('Kesalahan jaringan');
            }
        }

        async function assignKelasModal() {
            const jadwalId = document.getElementById('jadwalId').value;
            const kelasId = document.getElementById('selectKelasBaru').value;
            if(!jadwalId || !kelasId) return alert('Silakan pilih jadwal dan kelas terlebih dahulu!');
            
            try {
                const res = await fetch(`http://localhost:3000/api/jadwal/${jadwalId}/assign`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ kelasId })
                });
                if(res.ok) window.location.reload();
                else alert('Gagal menambahkan kelas ke jadwal');
            } catch(err) {
                alert('Kesalahan jaringan');
            }
        }

        async function hapusJadwal(id) {
            event.stopPropagation();
            if(confirm('Apakah Anda yakin ingin menghapus jadwal ini?')) {
                try {
                    const res = await fetch(`http://localhost:3000/api/jadwal/${id}`, { method: 'DELETE' });
                    if(res.ok) window.location.reload();
                    else alert('Gagal menghapus jadwal');
                } catch(err) { alert('Kesalahan jaringan'); }
            }
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            const id = data.id;
            delete data.id;

            const url = id ? `http://localhost:3000/api/jadwal/${id}` : 'http://localhost:3000/api/jadwal';
            const method = id ? 'PUT' : 'POST';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if(res.ok) window.location.reload();
                else alert('Gagal menyimpan jadwal');
            } catch (err) { alert('Terjadi kesalahan jaringan'); }
        });

        function showParams(checkin, late, checkout) {
            document.getElementById('param-checkin').value = checkin || '--';
            document.getElementById('param-late').value = late || '--';
            document.getElementById('param-checkout').value = checkout || '--';
        }

        const draggables = document.querySelectorAll('.draggable');
        const dropZones = document.querySelectorAll('.drop-zone');

        draggables.forEach(draggable => {
            draggable.addEventListener('dragstart', () => {
                draggable.classList.add('opacity-50');
                draggable.dataset.dragging = 'true';
            });
            draggable.addEventListener('dragend', () => {
                draggable.classList.remove('opacity-50');
                delete draggable.dataset.dragging;
            });
        });

        dropZones.forEach(zone => {
            zone.addEventListener('dragover', (e) => {
                e.preventDefault();
                zone.classList.add('drag-over');
            });
            zone.addEventListener('dragleave', () => {
                zone.classList.remove('drag-over');
            });
            zone.addEventListener('drop', async (e) => {
                e.preventDefault();
                zone.classList.remove('drag-over');
                const draggedItem = document.querySelector('[data-dragging="true"]');
                if (draggedItem) {
                    const kelasId = draggedItem.getAttribute('data-kelas-id');
                    const jadwalId = zone.getAttribute('data-jadwal-id');

                    try {
                        const res = await fetch(`http://localhost:3000/api/jadwal/${jadwalId}/assign`, {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ kelasId })
                        });
                        if (res.ok) window.location.reload();
                        else alert('Gagal menetapkan kelas ke jadwal');
                    } catch (err) { alert('Terjadi kesalahan jaringan'); }
                }
            });
        });
    </script>
</body>
</html>