    <main class="flex-1 ml-64 p-8">
        
        <div class="mb-6 flex items-center gap-4">
            <a href="/enrolment" class="bg-white p-2 rounded-full shadow hover:bg-gray-50 transition text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            </a>
            <div>
                <h1 class="text-2xl font-bold text-gray-800">Detail Kelas: <%= detail.enrolment.masterKelas.namaKelas %></h1>
                <p class="text-gray-500 text-sm">Angkatan <%= detail.enrolment.masterAngkatan.nomorAngkatan %> | TA <%= detail.enrolment.masterTahunAkademik.tahunAjaran %> (<%= detail.enrolment.masterTahunAkademik.semester %>)</p>
            </div>
        </div>

        <!-- TOP ROW: WALI KELAS & PENCARIAN -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            
            <!-- PANEL WALI KELAS -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col h-auto">
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">👨‍🏫 Wali Kelas</h2>
                        <p class="text-sm text-gray-500"><%= detail.enrolment.enrolmentGuru.length > 0 ? 'Sudah Diatur' : 'Belum Diatur' %></p>
                    </div>
                    <button onclick="toggleModal('modalTambahGuru')" class="bg-yellow-100 text-yellow-700 px-4 py-2 rounded-full text-xs font-bold shadow-md hover:bg-yellow-200 transition"><%= detail.enrolment.enrolmentGuru.length > 0 ? 'Ganti Wali Kelas' : '+ Atur Wali Kelas' %></button>
                </div>
                <div>
                    <% if (detail.enrolment.enrolmentGuru.length > 0) { %>
                        <% detail.enrolment.enrolmentGuru.forEach(function(eg) { %>
                            <div class="flex justify-between items-center p-4 bg-slate-50 rounded-xl border border-gray-100">
                                <div>
                                    <p class="font-bold text-gray-700"><%= eg.guru.namaLengkap %></p>
                                    <p class="font-mono text-xs text-gray-500">NIP: <%= eg.guru.nip %></p>
                                </div>
                                <form action="/enrolment/<%= detail.enrolment.id %>/guru/delete/<%= eg.guru.id %>" method="POST" onsubmit="return confirmDelete(event, this, 'Hapus guru ini sebagai wali kelas?');">
                                    <button type="submit" class="bg-red-100 text-red-600 px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-red-200">Hapus</button>
                                </form>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="p-4 bg-yellow-50 text-yellow-700 rounded-xl border border-yellow-100 text-center text-sm font-bold">
                            Wali kelas belum diatur.
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- PANEL PENCARIAN SISWA -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col h-auto justify-center">
                <h2 class="text-lg font-bold text-gray-800 flex items-center gap-2 mb-2">🔍 Cari Siswa di Kelas Ini</h2>
                <p class="text-sm text-gray-500 mb-4">Temukan siswa berdasarkan nama atau NIS dengan cepat.</p>
                <input type="text" id="searchInput" onkeyup="filterSiswa()" placeholder="Ketik nama atau NIS..." class="w-full bg-slate-50 border border-gray-200 rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light transition shadow-inner">
            </div>

        </div>

        <!-- PANEL SISWA (FULL WIDTH) -->
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col h-[600px]">
            <div class="flex justify-between items-center mb-6">
                <div>
                    <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">👤 Daftar Siswa</h2>
                    <p class="text-sm text-gray-500"><%= detail.enrolment.enrolmentSiswa.length %> Siswa tergabung</p>
                </div>
                <div class="flex gap-2">
                    <button type="submit" form="formKenaikanKelas" class="bg-indigo-600 text-white px-4 py-2 rounded-full text-xs font-bold shadow-md hover:bg-indigo-700 transition">💾 Simpan Status Kenaikan</button>
                    <button onclick="toggleModal('modalTambahSiswa')" class="bg-primary text-white px-4 py-2 rounded-full text-xs font-bold shadow-md hover:bg-primary-dark transition">+ Tambah Siswa</button>
                </div>
            </div>
            <form id="formKenaikanKelas" action="/enrolment/<%= detail.enrolment.id %>/proses-kenaikan" method="POST" class="overflow-y-auto flex-1 border rounded-xl" onsubmit="return confirmProses(event, this);">
                <table class="w-full text-left" id="tableSiswa">
                    <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase tracking-wider font-bold sticky top-0">
                        <tr>
                            <th class="px-4 py-3">Nama Siswa</th>
                            <th class="px-4 py-3">NIS</th>
                            <th class="px-4 py-3 text-center">Status Kenaikan</th>
                            <th class="px-4 py-3 text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y text-sm">
                        <% if (detail.enrolment.enrolmentSiswa.length > 0) { %>
                            <% detail.enrolment.enrolmentSiswa.forEach(function(es) { %>
                                <tr class="hover:bg-slate-50">
                                    <td class="px-4 py-3 font-bold text-gray-700"><%= es.siswa.namaLengkap %></td>
                                    <td class="px-4 py-3 font-mono text-xs text-gray-500"><%= es.siswa.nis %></td>
                                    <td class="px-4 py-3 text-center">
                                        <select name="status_<%= es.siswa.id %>" class="bg-slate-50 border border-gray-200 rounded-md px-2 py-1 text-xs outline-none focus:border-primary-light">
                                            <option value="" <%= (!es.statusKenaikan || es.statusKenaikan === 'Belum Diproses') ? 'selected' : '' %>>Belum Diproses</option>
                                            <% if (detail.enrolment.masterKelas.tingkat && detail.enrolment.masterKelas.tingkat.namaTingkat === 'XII') { %>
                                                <option value="lulus" <%= es.statusKenaikan === 'Lulus' ? 'selected' : '' %>>Lulus</option>
                                            <% } else { %>
                                                <option value="naik" <%= es.statusKenaikan === 'Naik Kelas' ? 'selected' : '' %>>Naik Kelas</option>
                                            <% } %>
                                            <option value="cuti" <%= es.statusKenaikan === 'Tidak Naik / Cuti' ? 'selected' : '' %>>Tidak Naik / Cuti</option>
                                        </select>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <button type="button" onclick="confirmDeleteIndividual('<%= detail.enrolment.id %>', '<%= es.siswa.id %>')" class="bg-red-100 text-red-600 px-2 py-1 rounded-md text-xs font-bold hover:bg-red-200">Keluarkan</button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr><td colspan="4" class="px-4 py-8 text-center text-gray-500 font-bold text-sm">Belum ada siswa di kelas ini.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </form>
        </div>
    </main>

    <!-- MODAL TAMBAH SISWA -->
    <div id="modalTambahSiswa" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl relative">
            <button onclick="toggleModal('modalTambahSiswa')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-6">Pilih Siswa</h2>
            <form action="/enrolment/<%= detail.enrolment.id %>/siswa" method="POST" class="space-y-4">
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase">Pilih dari Daftar Siswa</label>
                    <select name="siswaId" required class="w-full mt-1 bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light">
                        <option value="">-- Pilih Siswa --</option>
                        <% detail.allSiswa.forEach(s => { %>
                            <option value="<%= s.id %>"><%= s.namaLengkap %> (NIS: <%= s.nis %>)</option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="w-full bg-primary text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-primary-dark">Tambahkan Siswa</button>
            </form>
        </div>
    </div>

    <!-- MODAL TAMBAH GURU -->
    <div id="modalTambahGuru" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl relative">
            <button onclick="toggleModal('modalTambahGuru')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-6">Pilih Wali Kelas</h2>
            <form action="/enrolment/<%= detail.enrolment.id %>/guru" method="POST" class="space-y-4">
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase">Pilih dari Daftar Guru</label>
                    <select name="guruId" required class="w-full mt-1 bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-primary-light">
                        <option value="">-- Pilih Guru --</option>
                        <% detail.allGuru.forEach(g => { %>
                            <option value="<%= g.id %>"><%= g.namaLengkap %> (NIP: <%= g.nip %>)</option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="w-full bg-yellow-400 text-yellow-900 font-bold rounded-xl py-3.5 mt-4 hover:bg-yellow-500">Simpan Wali Kelas</button>
            </form>
        </div>
    </div>

    <script>
        function toggleModal(modalID) {
            const modal = document.getElementById(modalID);
            modal.classList.toggle('hidden');
        }

        function confirmDelete(e, form, text) {
            e.preventDefault();
            Swal.fire({
                title: 'Konfirmasi', text: text, icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#ef4444', cancelButtonColor: '#64748b', confirmButtonText: 'Ya, Lanjutkan!'
            }).then((result) => {
                if (result.isConfirmed) form.submit();
            });
        }
        function confirmProses(e, form) {
            e.preventDefault();
            Swal.fire({
                title: 'Proses Status Kenaikan?',
                text: 'Siswa yang terpilih Naik Kelas atau Lulus akan dipindahkan, sedangkan yang Cuti/Tidak Naik akan dinonaktifkan dari kelas ini.',
                icon: 'question',
                showCancelButton: true, confirmButtonColor: '#4f46e5', cancelButtonColor: '#64748b', confirmButtonText: 'Ya, Proses Sekarang!'
            }).then((result) => {
                if (result.isConfirmed) form.submit();
            });
        }
        function confirmDeleteIndividual(kelasId, siswaId) {
            Swal.fire({
                title: 'Konfirmasi', text: 'Keluarkan siswa ini dari kelas?', icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#ef4444', cancelButtonColor: '#64748b', confirmButtonText: 'Ya, Keluarkan!'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = `/enrolment/${kelasId}/siswa/delete/${siswaId}`;
                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }
        function filterSiswa() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            const rows = document.querySelectorAll('#tableSiswa tbody tr');
            rows.forEach(row => {
                if (row.children.length > 1) { // abaikan baris "Belum ada siswa"
                    const nama = row.children[0].innerText.toLowerCase();
                    const nis = row.children[1].innerText.toLowerCase();
                    if (nama.includes(input) || nis.includes(input)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                }
            });
        }
    </script>

</body>
</html>

