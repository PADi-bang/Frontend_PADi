<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Detail Kelas - App_PADi</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-slate-100 flex font-sans">
    
    <aside class="w-64 h-screen bg-black text-gray-400 p-6 flex flex-col fixed rounded-r-3xl shadow-2xl z-20">
        <div class="text-3xl font-bold text-white mb-12 mt-4 tracking-widest pl-2">PADi</div>
        <nav class="flex-1 space-y-3">
            <a href="/dashboard" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">⊞</span> Dashboard
            </a>
            <a href="/daftar-siswa" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">👤</span> Daftar Siswa
            </a>
            <a href="/daftar-guru" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">👨‍🏫</span> Daftar Guru
            </a>
            <a href="/jadwal" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">📅</span> Jadwal
            </a>
            <a href="/master-data" class="flex items-center gap-4 p-3.5 hover:text-white hover:bg-white/10 rounded-2xl transition">
                <span class="text-lg">🗂️</span> Master Data
            </a>
            <a href="/enrolment" class="flex items-center gap-4 p-3.5 bg-blue-600 text-white rounded-2xl shadow-lg shadow-blue-600/40 transition">
                <span class="text-lg">🎓</span> Enrolment Kelas
            </a>
        </nav>
        <div class="mt-auto mb-4">
            <a href="/logout" class="flex justify-center items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 px-4 rounded-full transition shadow-lg shadow-blue-600/30">
                <span class="text-lg">⎋</span> LOGOUT
            </a>
        </div>
    </aside>

    <main class="flex-1 ml-64 p-8">
        
        <div class="mb-6 flex items-center gap-4">
            <a href="/enrolment" class="bg-white p-2 rounded-full shadow hover:bg-gray-50 transition text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            </a>
            <div>
                <h1 class="text-2xl font-bold text-gray-800">Detail Kelas: <%= detail.enrolment.masterKelas.namaKelas %></h1>
                <p class="text-gray-500 text-sm">Angkatan <%= detail.enrolment.masterAngkatan.nomorAngkatan %> | TA <%= detail.enrolment.masterTahunAkademik.tahunAjaran %> (<%= detail.enrolment.masterTahunAkademik.semester %>)</p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            
            <!-- PANEL SISWA -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col h-[600px]">
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">👤 Daftar Siswa</h2>
                        <p class="text-sm text-gray-500"><%= detail.enrolment.enrolmentSiswa.length %> Siswa tergabung</p>
                    </div>
                    <button onclick="toggleModal('modalTambahSiswa')" class="bg-blue-600 text-white px-4 py-2 rounded-full text-xs font-bold shadow-md hover:bg-blue-700 transition">+ Tambah Siswa</button>
                </div>
                <div class="overflow-y-auto flex-1 border rounded-xl">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase tracking-wider font-bold sticky top-0">
                            <tr>
                                <th class="px-4 py-3">Nama Siswa</th>
                                <th class="px-4 py-3">NIS</th>
                                <th class="px-4 py-3 text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y text-sm">
                            <% if (detail.enrolment.enrolmentSiswa.length > 0) { %>
                                <% detail.enrolment.enrolmentSiswa.forEach(function(es) { %>
                                    <tr class="hover:bg-slate-50">
                                        <td class="px-4 py-3 font-bold text-gray-700"><%= es.siswa.namaLengkap %></td>
                                        <td class="px-4 py-3 font-mono text-xs text-gray-500"><%= es.siswa.nis %></td>
                                        <td class="px-4 py-3 text-center">
                                            <form action="/enrolment/<%= detail.enrolment.id %>/siswa/delete/<%= es.siswa.id %>" method="POST" onsubmit="return confirmDelete(event, this, 'Keluarkan siswa ini dari kelas?');">
                                                <button type="submit" class="bg-red-100 text-red-600 px-2 py-1 rounded-md text-xs font-bold hover:bg-red-200">Keluarkan</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="3" class="px-4 py-8 text-center text-gray-500 font-bold text-sm">Belum ada siswa di kelas ini.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- PANEL GURU -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col h-[600px]">
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">👨‍🏫 Daftar Guru (Pengajar)</h2>
                        <p class="text-sm text-gray-500"><%= detail.enrolment.enrolmentGuru.length %> Guru tergabung</p>
                    </div>
                    <button onclick="toggleModal('modalTambahGuru')" class="bg-green-600 text-white px-4 py-2 rounded-full text-xs font-bold shadow-md hover:bg-green-700 transition">+ Tambah Guru</button>
                </div>
                <div class="overflow-y-auto flex-1 border rounded-xl">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50 text-[10px] text-gray-400 uppercase tracking-wider font-bold sticky top-0">
                            <tr>
                                <th class="px-4 py-3">Nama Guru</th>
                                <th class="px-4 py-3">NIP</th>
                                <th class="px-4 py-3 text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y text-sm">
                            <% if (detail.enrolment.enrolmentGuru.length > 0) { %>
                                <% detail.enrolment.enrolmentGuru.forEach(function(eg) { %>
                                    <tr class="hover:bg-slate-50">
                                        <td class="px-4 py-3 font-bold text-gray-700"><%= eg.guru.namaLengkap %></td>
                                        <td class="px-4 py-3 font-mono text-xs text-gray-500"><%= eg.guru.nip %></td>
                                        <td class="px-4 py-3 text-center">
                                            <form action="/enrolment/<%= detail.enrolment.id %>/guru/delete/<%= eg.guru.id %>" method="POST" onsubmit="return confirmDelete(event, this, 'Keluarkan guru ini dari kelas?');">
                                                <button type="submit" class="bg-red-100 text-red-600 px-2 py-1 rounded-md text-xs font-bold hover:bg-red-200">Keluarkan</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="3" class="px-4 py-8 text-center text-gray-500 font-bold text-sm">Belum ada guru di kelas ini.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

    <!-- MODAL TAMBAH SISWA -->
    <div id="modalTambahSiswa" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl relative">
            <button onclick="toggleModal('modalTambahSiswa')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-6">Pilih Siswa</h2>
            <form action="/enrolment/<%= detail.enrolment.id %>/siswa" method="POST" class="space-y-4">
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase">Pilih dari Daftar Siswa</label>
                    <select name="siswaId" required class="w-full mt-1 bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-blue-500">
                        <option value="">-- Pilih Siswa --</option>
                        <% detail.allSiswa.forEach(s => { %>
                            <option value="<%= s.id %>"><%= s.namaLengkap %> (NIS: <%= s.nis %>)</option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="w-full bg-blue-600 text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-blue-700">Tambahkan Siswa</button>
            </form>
        </div>
    </div>

    <!-- MODAL TAMBAH GURU -->
    <div id="modalTambahGuru" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex justify-center items-center">
        <div class="bg-white rounded-3xl p-8 w-full max-w-md shadow-2xl relative">
            <button onclick="toggleModal('modalTambahGuru')" class="absolute top-6 right-6 text-gray-400 hover:text-black font-bold">✖</button>
            <h2 class="text-2xl font-bold text-gray-800 mb-6">Pilih Guru</h2>
            <form action="/enrolment/<%= detail.enrolment.id %>/guru" method="POST" class="space-y-4">
                <div>
                    <label class="text-xs font-bold text-gray-500 uppercase">Pilih dari Daftar Guru</label>
                    <select name="guruId" required class="w-full mt-1 bg-slate-50 border rounded-xl px-4 py-3 text-sm outline-none focus:border-blue-500">
                        <option value="">-- Pilih Guru --</option>
                        <% detail.allGuru.forEach(g => { %>
                            <option value="<%= g.id %>"><%= g.namaLengkap %> (NIP: <%= g.nip %>)</option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="w-full bg-green-600 text-white font-bold rounded-xl py-3.5 mt-4 hover:bg-green-700">Tambahkan Guru</button>
            </form>
        </div>
    </div>

    <script>
        function toggleModal(modalID) {
            const modal = document.getElementById(modalID);
            modal.classList.toggle('hidden');
        }

        function confirmDelete(e, form, text) {
            e.preventDefault();
            Swal.fire({
                title: 'Konfirmasi', text: text, icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#ef4444', cancelButtonColor: '#64748b', confirmButtonText: 'Ya, Lanjutkan!'
            }).then((result) => {
                if (result.isConfirmed) form.submit();
            });
        }
    </script>
</body>
</html>
