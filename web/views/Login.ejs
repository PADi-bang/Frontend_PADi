<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Vocational Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 font-sans">
    <div class="flex h-screen">
        <div class="hidden lg:flex w-1/2 bg-[#006652] p-12 flex-col justify-center text-white relative">
            <h1 class="text-5xl font-bold mb-4">Ignite Your <span class="text-green-300">Professional</span> Journey.</h1>
            <p class="text-lg opacity-80 mb-8">Access the centralized system for vocational excellence, attendance management, and apprentice growth tracking.</p>
            
            <div class="flex gap-4">
                <div class="bg-white/20 p-6 rounded-xl backdrop-blur-md w-40">
                    <p class="text-2xl font-bold">12K+</p>
                    <p class="text-xs">ACTIVE APPRENTICES</p>
                </div>
                <div class="bg-white/20 p-6 rounded-xl backdrop-blur-md w-40">
                    <p class="text-2xl font-bold">450+</p>
                    <p class="text-xs">PARTNER INDUSTRIES</p>
                </div>
            </div>
        </div>

        <div class="w-full lg:w-1/2 flex flex-col justify-center px-12 md:px-24">
            <div class="mb-8">
                <h2 class="text-3xl font-bold text-gray-800">Welcome Back</h2>
                <p class="text-gray-500">Masuk ke akun Vocational Portal Anda.</p>
            </div>

            <form id="loginForm" class="space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1">Email</label>
                    <input type="email" id="email" placeholder="nama@sekolah.sch.id" required
                        class="w-full px-4 py-2.5 border rounded-xl text-sm bg-gray-50 outline-none focus:border-[#006652]">
                </div>

                <div>
                    <div class="flex justify-between items-center mb-1">
                        <label class="block text-xs font-semibold text-gray-600">Password</label>
                        <a href="#" class="text-xs text-orange-600 hover:underline">Lupa Password?</a>
                    </div>
                    <input type="password" id="password" placeholder="Masukkan password" required
                        class="w-full px-4 py-2.5 border rounded-xl text-sm bg-gray-50 outline-none focus:border-[#006652]">
                </div>

                <div class="flex items-center gap-2 py-1">
                    <input type="checkbox" id="remember" class="rounded text-[#006652]">
                    <label for="remember" class="text-xs text-gray-500">Tetap masuk di perangkat ini</label>
                </div>

                <button type="submit" class="w-full bg-[#006652] text-white py-3 rounded-xl font-bold text-sm hover:bg-[#005241] transition flex justify-center items-center gap-2">
                    Masuk ➔
                </button>
            </form>

            <div id="errorMessage" class="text-xs text-red-500 font-semibold mt-3 hidden text-center"></div>

            <div class="mt-8 text-center text-xs text-gray-500">
                Belum memiliki akun? <a href="#" class="text-[#006652] font-bold">Daftar sekarang</a>
            </div>
        </div>
    </div>

    <script>
    document.getElementById('loginForm').addEventListener('submit', async (e) => {
        e.preventDefault(); // Mencegah form melakukan reload halaman otomatis

        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;
        const errorMessage = document.getElementById('errorMessage');

        // Reset status error message
        errorMessage.classList.add('hidden');
        errorMessage.innerText = "";

        try {
            // Tembak endpoint API login backend ke port 3000
            const response = await fetch('http://localhost:3000/api/auth/login', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ email, password })
            });

            const result = await response.json();

            if (result.success) {
                // 1. Simpan Token JWT dan data user ke LocalStorage browser
                localStorage.setItem('admin_token', result.token);
                localStorage.setItem('admin_user', JSON.stringify(result.user));

                // 2. Alihkan halaman langsung ke Dashboard Admin jika login sukses
                window.location.href = '/dashboard';
            } else {
                // Tampilkan pesan gagal spesifik yang dikirim dari backend
                errorMessage.innerText = result.message || "Login gagal, silakan coba lagi.";
                errorMessage.classList.remove('hidden');
            }

        } catch (error) {
            console.error("Error saat login:", error);
            errorMessage.innerText = "Tidak dapat terhubung ke server backend.";
            errorMessage.classList.remove('hidden');
        }
    });
</script>
</body>
</html>